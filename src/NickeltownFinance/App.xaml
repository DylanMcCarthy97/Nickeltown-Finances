<Application x:Class="NickeltownFinance.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:NickeltownFinance.Converters"
             xmlns:vm="clr-namespace:NickeltownFinance.ViewModels"
             xmlns:views="clr-namespace:NickeltownFinance.Views.Pages"
             Startup="OnStartup"
             Exit="OnExit">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="Themes/BrandTheme.xaml" />
                <ResourceDictionary Source="Themes/DesignSystem.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:CurrencyConverter x:Key="CurrencyConverter" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <conv:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" />
            <conv:NotNullToBoolConverter x:Key="NotNullToBoolConverter" />
            <conv:MonthNameConverter x:Key="MonthNameConverter" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
            <conv:PasswordVisibilityLabelConverter x:Key="PasswordVisibilityLabelConverter" />
            <conv:ZeroToDashConverter x:Key="ZeroToDashConverter" />
            <conv:SidebarLabelConverter x:Key="SidebarLabelConverter" />
            <conv:EmptyCollectionToVisibilityConverter x:Key="EmptyCollectionToVisibilityConverter" />
            <conv:StringEqualsConverter x:Key="StringEqualsConverter" />
            <conv:PathToImageSourceConverter x:Key="PathToImageSourceConverter" />
            <conv:RoleDisplayConverter x:Key="RoleDisplayConverter" />
            <conv:StatusBadgeBackgroundConverter x:Key="StatusBadgeBackgroundConverter" />
            <conv:PasswordStrengthBrushConverter x:Key="PasswordStrengthBrushConverter" />
            <conv:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter" />
            <conv:ConfidenceToBrushConverter x:Key="ConfidenceToBrushConverter" />
            <conv:ConfidenceDisplayConverter x:Key="ConfidenceDisplayConverter" />
            <conv:MatchQualityBrushConverter x:Key="MatchQualityBrushConverter" />
            <conv:NullToDefaultImageConverter x:Key="ClubLogoOrDefaultConverter"
                                             DefaultImage="{StaticResource DefaultClubLogoImage}" />

            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:TransactionsViewModel}">
                <views:TransactionsPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ImportViewModel}">
                <views:ImportPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ReceiptInboxViewModel}">
                <views:ReceiptInboxPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ReconciliationViewModel}">
                <views:ReconciliationPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                <views:ReportsPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MonthlyReportViewModel}">
                <views:MonthlyReportPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AgmReportViewModel}">
                <views:AgmReportPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:UserManagementViewModel}">
                <views:UserManagementPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:FinancialYearsViewModel}">
                <views:FinancialYearsPage />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
