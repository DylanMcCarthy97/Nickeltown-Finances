<UserControl x:Class="NickeltownFinance.Controls.StatisticRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Margin="0,4">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="{Binding Label, ElementName=Root}" Opacity="0.7" TextTrimming="CharacterEllipsis" />
        <TextBlock Grid.Column="1"
                   Text="{Binding Value, ElementName=Root}"
                   HorizontalAlignment="Right"
                   FontWeight="{Binding ValueFontWeight, ElementName=Root}"
                   Foreground="{Binding ValueBrush, ElementName=Root}"
                   Margin="12,0,0,0" />
    </Grid>
</UserControl>
