<UserControl x:Class="NickeltownFinance.Controls.ReportLine"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Margin="{Binding LineMargin, ElementName=Root}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="{Binding Label, ElementName=Root}"
                   FontWeight="{Binding LabelFontWeight, ElementName=Root}"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock Grid.Column="1"
                   Text="{Binding AmountText, ElementName=Root}"
                   FontWeight="{Binding LabelFontWeight, ElementName=Root}"
                   Margin="12,0,0,0" />
    </Grid>
</UserControl>
