<UserControl x:Class="NickeltownFinance.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Background="{Binding BadgeBackground, ElementName=Root}"
            CornerRadius="6"
            Padding="8,3"
            VerticalAlignment="Center"
            HorizontalAlignment="Left">
        <TextBlock Text="{Binding Text, ElementName=Root}"
                   Foreground="{Binding BadgeForeground, ElementName=Root}"
                   FontWeight="SemiBold"
                   FontSize="11"
                   FontFamily="{StaticResource AppFontFamily}" />
    </Border>
</UserControl>
