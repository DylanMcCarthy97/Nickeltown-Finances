<UserControl x:Class="NickeltownFinance.Controls.EmptyState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             x:Name="Root">
    <Border Style="{StaticResource DropZoneStyle}" Padding="48,40">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
            <Border Style="{StaticResource IconBadgeLargeStyle}"
                    Background="{StaticResource BrandAccentFillBrush}"
                    HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="{Binding IconSymbol, ElementName=Root}"
                               FontSize="24"
                               Foreground="{StaticResource BrandPrimaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="{Binding Title, ElementName=Root}"
                       Style="{StaticResource SectionTitleStyle}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,20,0,0"
                       Visibility="{Binding Title, ElementName=Root, Converter={StaticResource NullToVisibilityConverter}}" />
            <TextBlock Text="{Binding Message, ElementName=Root}"
                       Style="{StaticResource PageSubtitleStyle}"
                       Margin="0,8,0,0"
                       TextAlignment="Center" />
            <ContentPresenter Content="{Binding ActionContent, ElementName=Root}"
                              HorizontalAlignment="Center"
                              Margin="0,20,0,0"
                              Visibility="{Binding ActionContent, ElementName=Root, Converter={StaticResource NullToVisibilityConverter}}" />
        </StackPanel>
    </Border>
</UserControl>
