<UserControl x:Class="NickeltownFinance.Controls.ReportCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Style="{StaticResource AppCardStyle}" Padding="28">
        <StackPanel>
            <TextBlock Text="{Binding ClubName, ElementName=Root}"
                       Style="{StaticResource ReportHeaderClubNameStyle}"
                       Visibility="{Binding ClubName, ElementName=Root, Converter={StaticResource NullToVisibilityConverter}}" />
            <TextBlock Text="{Binding ReportTitle, ElementName=Root}"
                       Style="{StaticResource SectionTitleStyle}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,8,0,0"
                       Visibility="{Binding ReportTitle, ElementName=Root, Converter={StaticResource NullToVisibilityConverter}}" />
            <TextBlock Text="{Binding Subtitle, ElementName=Root}"
                       Style="{StaticResource PageSubtitleStyle}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,4,0,20"
                       Visibility="{Binding Subtitle, ElementName=Root, Converter={StaticResource NullToVisibilityConverter}}" />
            <ContentPresenter Content="{Binding Body, ElementName=Root}" />
        </StackPanel>
    </Border>
</UserControl>
