<UserControl x:Class="NickeltownFinance.Controls.AppDateField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="40"
             MinWidth="140"
             FontFamily="{StaticResource AppFontFamily}"
             FontSize="14">
    <DatePicker SelectedDate="{Binding SelectedDate, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                CalendarStyle="{StaticResource AppCalendarStyle}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />
</UserControl>
