<UserControl x:Class="NickeltownFinance.Controls.SearchBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             x:Name="Root">
    <Border Background="{DynamicResource BrandInsetBrush}"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="10"
            Padding="4,0"
            MinHeight="40">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:SymbolIcon Symbol="Search24"
                           FontSize="16"
                           Foreground="{DynamicResource BrandMutedTextBrush}"
                           Margin="12,0,4,0"
                           VerticalAlignment="Center" />

            <ui:TextBox Grid.Column="1"
                        Style="{StaticResource AppSearchBoxStyle}"
                        MinWidth="{Binding MinSearchWidth, ElementName=Root}"
                        Width="{Binding SearchWidth, ElementName=Root}"
                        PlaceholderText="{Binding Placeholder, ElementName=Root}"
                        Text="{Binding Text, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Margin="{Binding TextBoxMargin, ElementName=Root}"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="{DynamicResource BrandTextPrimaryBrush}"
                        VerticalAlignment="Center"
                        MinHeight="36" />

            <ui:Button Grid.Column="2"
                       Content="{Binding ButtonText, ElementName=Root}"
                       Icon="{ui:SymbolIcon Search24}"
                       Style="{StaticResource ToolbarButtonStyle}"
                       Command="{Binding SearchCommand, ElementName=Root}"
                       Visibility="{Binding ShowButton, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>
    </Border>
</UserControl>
