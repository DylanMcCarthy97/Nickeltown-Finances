<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- ============================================================
         Nickeltown Finance — Brand palette (default: dark)
         Brushes are unfrozen so ThemeService can switch light/dark live.
         ============================================================ -->

    <!-- Core surfaces — deep, layered (modern dark UI) -->
    <Color x:Key="BrandBackgroundColor">#0C0E13</Color>
    <Color x:Key="BrandSurfaceColor">#151820</Color>
    <Color x:Key="BrandSidebarColor">#10131A</Color>
    <Color x:Key="BrandElevatedColor">#1C212C</Color>
    <Color x:Key="BrandBorderColor">#2A3040</Color>
    <Color x:Key="BrandBorderSubtleColor">#1E2430</Color>

    <!-- Accents -->
    <Color x:Key="BrandPrimaryColor">#4B9EFF</Color>
    <Color x:Key="BrandPrimaryHoverColor">#6BB0FF</Color>
    <Color x:Key="BrandPrimaryPressedColor">#2B7AE8</Color>
    <Color x:Key="BrandSuccessColor">#22C55E</Color>
    <Color x:Key="BrandWarningColor">#F59E0B</Color>
    <Color x:Key="BrandDangerColor">#EF4444</Color>

    <!-- Semantic money tones -->
    <Color x:Key="BrandIncomeColor">#22C55E</Color>
    <Color x:Key="BrandExpenseColor">#EF4444</Color>
    <Color x:Key="BrandProfitColor">#2D8CFF</Color>
    <Color x:Key="BrandBalanceColor">#2D8CFF</Color>

    <!-- Text -->
    <Color x:Key="BrandTextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="BrandTextSecondaryColor">#A8B2C0</Color>
    <Color x:Key="BrandMutedTextColor">#6B7788</Color>

    <!-- Legacy aliases (pages / controls) -->
    <Color x:Key="BrandPrimaryMidColor">#232833</Color>
    <Color x:Key="BrandAccentColor">#2D8CFF</Color>
    <Color x:Key="BrandAccentSoftColor">#7AB8FF</Color>
    <Color x:Key="BrandCardColor">#232833</Color>

    <!-- Brushes (po:Freeze=False so ThemeService can mutate Color) -->
    <SolidColorBrush x:Key="BrandBackgroundBrush" Color="{StaticResource BrandBackgroundColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandSurfaceBrush" Color="{StaticResource BrandSurfaceColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandSidebarBrush" Color="{StaticResource BrandSidebarColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandElevatedBrush" Color="{StaticResource BrandElevatedColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandBorderBrush" Color="{StaticResource BrandBorderColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandBorderSubtleBrush" Color="{StaticResource BrandBorderSubtleColor}" po:Freeze="False" />

    <SolidColorBrush x:Key="BrandPrimaryBrush" Color="{StaticResource BrandPrimaryColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandPrimaryHoverBrush" Color="{StaticResource BrandPrimaryHoverColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandPrimaryPressedBrush" Color="{StaticResource BrandPrimaryPressedColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandPrimaryMidBrush" Color="{StaticResource BrandPrimaryMidColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandAccentBrush" Color="{StaticResource BrandAccentColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandAccentSoftBrush" Color="{StaticResource BrandAccentSoftColor}" po:Freeze="False" />

    <SolidColorBrush x:Key="BrandSuccessBrush" Color="{StaticResource BrandSuccessColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandWarningBrush" Color="{StaticResource BrandWarningColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandDangerBrush" Color="{StaticResource BrandDangerColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandIncomeBrush" Color="{StaticResource BrandIncomeColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandExpenseBrush" Color="{StaticResource BrandExpenseColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandProfitBrush" Color="{StaticResource BrandProfitColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandBalanceBrush" Color="{StaticResource BrandBalanceColor}" po:Freeze="False" />

    <SolidColorBrush x:Key="BrandTextPrimaryBrush" Color="{StaticResource BrandTextPrimaryColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandTextSecondaryBrush" Color="{StaticResource BrandTextSecondaryColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandMutedTextBrush" Color="{StaticResource BrandMutedTextColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandCardBrush" Color="{StaticResource BrandCardColor}" po:Freeze="False" />

    <!-- Soft fills (12–18% opacity) -->
    <SolidColorBrush x:Key="BrandAccentFillBrush" Color="#334B9EFF" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandNavActiveBrush" Color="#384B9EFF" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandNavHoverBrush" Color="#12FFFFFF" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandInsetBrush" Color="#0AFFFFFF" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandGlassBrush" Color="#CC10131A" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandIncomeFillBrush" Color="#2922C55E" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandExpenseFillBrush" Color="#29EF4444" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandProfitFillBrush" Color="#292D8CFF" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandBalanceFillBrush" Color="#292D8CFF" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandSuccessFillBrush" Color="#2922C55E" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandWarningFillBrush" Color="#29F59E0B" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandDangerFillBrush" Color="#29EF4444" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandErrorBrush" Color="#EF4444" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandRowAltBrush" Color="#0CFFFFFF" po:Freeze="False" />
    <SolidColorBrush x:Key="BrandOverlayBrush" Color="#D90C0E13" po:Freeze="False" />

    <!-- Override WPF-UI chrome -->
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource BrandBackgroundColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource BrandSurfaceColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource BrandElevatedColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{StaticResource BrandSurfaceColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource BrandTextPrimaryColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource BrandTextSecondaryColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource BrandMutedTextColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource BrandBorderColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{StaticResource BrandPrimaryColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="{StaticResource BrandPrimaryHoverColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="{StaticResource BrandPrimaryPressedColor}" po:Freeze="False" />

    <!-- Elevation (subtle, premium) -->
    <DropShadowEffect x:Key="CardShadow"
                      BlurRadius="24"
                      ShadowDepth="0"
                      Direction="270"
                      Opacity="0.35"
                      Color="#000000"
                      po:Freeze="False" />
    <DropShadowEffect x:Key="CardShadowSoft"
                      BlurRadius="16"
                      ShadowDepth="0"
                      Direction="270"
                      Opacity="0.22"
                      Color="#000000"
                      po:Freeze="False" />
    <DropShadowEffect x:Key="ElevatedShadow"
                      BlurRadius="40"
                      ShadowDepth="0"
                      Direction="270"
                      Opacity="0.45"
                      Color="#000000"
                      po:Freeze="False" />
    <DropShadowEffect x:Key="QuietSurfaceShadow"
                      BlurRadius="20"
                      ShadowDepth="0"
                      Direction="270"
                      Opacity="0.28"
                      Color="#000000"
                      po:Freeze="False" />

    <!-- Branding assets — transparent, never stretched into white boxes -->
    <BitmapImage x:Key="AppLogoImage"
                 UriSource="pack://application:,,,/Assets/AppIcon.png"
                 CacheOption="OnLoad" />
    <BitmapImage x:Key="DefaultClubLogoImage"
                 UriSource="pack://application:,,,/Assets/ClubLogo.png"
                 CacheOption="OnLoad" />

    <CornerRadius x:Key="RadiusSm">8</CornerRadius>
    <CornerRadius x:Key="RadiusMd">10</CornerRadius>
    <CornerRadius x:Key="RadiusLg">14</CornerRadius>
    <CornerRadius x:Key="RadiusXl">18</CornerRadius>

</ResourceDictionary>
