<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:controls="clr-namespace:NickeltownFinance.Controls"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ============================================================
         Design System — Typography, Controls, Surfaces
         Font: Segoe UI Variable → Inter → Segoe UI
         Spacing: 8px grid
         ============================================================ -->

    <FontFamily x:Key="AppFontFamily">Segoe UI Variable, Inter, Segoe UI, sans-serif</FontFamily>

    <!-- Semantic aliases (unfrozen for live theme switching) -->
    <SolidColorBrush x:Key="DsIncomeBrush" Color="{StaticResource BrandIncomeColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="DsExpenseBrush" Color="{StaticResource BrandExpenseColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="DsProfitBrush" Color="{StaticResource BrandProfitColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="DsErrorBrush" Color="{StaticResource BrandDangerColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="DsSuccessBrush" Color="{StaticResource BrandSuccessColor}" po:Freeze="False" />
    <SolidColorBrush x:Key="DsWarningBrush" Color="{StaticResource BrandWarningColor}" po:Freeze="False" />

    <!-- ========== TYPOGRAPHY SCALE ========== -->
    <Style x:Key="DisplayTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="40" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="LineHeight" Value="48" />
    </Style>

    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="CardTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource BrandMutedTextBrush}" />
    </Style>

    <Style x:Key="PageSubtitleStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
        <Setter Property="Margin" Value="0,6,0,0" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="MutedTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}" />

    <Style x:Key="MetricLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CardTitleStyle}">
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="MetricValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="HeroAmountStyle" TargetType="TextBlock" BasedOn="{StaticResource DisplayTextStyle}">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="DetailLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style x:Key="DetailValueStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,14" />
    </Style>

    <Style x:Key="ReportHeaderClubNameStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Legacy dashboard aliases -->
    <Style x:Key="DashboardEyebrowStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}" />
    <Style x:Key="DashboardHeroAmountStyle" TargetType="TextBlock" BasedOn="{StaticResource HeroAmountStyle}" />
    <Style x:Key="DashboardPulseLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CardTitleStyle}" />
    <Style x:Key="DashboardPulseValueStyle" TargetType="TextBlock" BasedOn="{StaticResource MetricValueStyle}">
        <Setter Property="FontSize" Value="22" />
    </Style>
    <Style x:Key="DashboardSectionLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleStyle}">
        <Setter Property="Margin" Value="0" />
    </Style>
    <Style x:Key="DashboardYtdLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}" />
    <Style x:Key="DashboardYtdValueStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <!-- ========== BUTTONS ========== -->
    <Style x:Key="PrimaryButtonStyle" TargetType="ui:Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource BrandPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrandPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Appearance" Value="Primary" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrandPrimaryHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource BrandPrimaryPressedBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="ui:Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource BrandElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Appearance" Value="Secondary" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrandNavHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Opacity" Value="0.85" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="ui:Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource BrandDangerBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Appearance" Value="Danger" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F87171" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#DC2626" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SuccessButtonStyle" TargetType="ui:Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource BrandSuccessBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Appearance" Value="Success" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#4ADE80" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#16A34A" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ToolbarButtonStyle" TargetType="ui:Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Appearance" Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrandNavHoverBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Opacity" Value="0.8" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="GhostButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style x:Key="DashboardGhostButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource GhostButtonStyle}" />
    <Style x:Key="DashboardPrimaryActionStyle" TargetType="ui:Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Margin" Value="0,0,8,0" />
    </Style>

    <!-- Grouped buttons — equal size within horizontal/wrapped toolbars -->
    <sys:Double x:Key="ButtonGroupMinWidth">132</sys:Double>
    <sys:Double x:Key="ButtonGroupMinWidthWide">156</sys:Double>
    <sys:Double x:Key="ButtonGroupMinWidthCompact">96</sys:Double>
    <sys:Double x:Key="ButtonGroupMinWidthExtraWide">220</sys:Double>
    <Thickness x:Key="ButtonGroupMargin">0,0,8,8</Thickness>
    <Thickness x:Key="ButtonGroupMarginInline">0,0,8,0</Thickness>

    <Style x:Key="GroupedPrimaryButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Width" Value="{StaticResource ButtonGroupMinWidth}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="GroupedSecondaryButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource SecondaryButtonStyle}">
        <Setter Property="Width" Value="{StaticResource ButtonGroupMinWidth}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="GroupedDangerButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource DangerButtonStyle}">
        <Setter Property="Width" Value="{StaticResource ButtonGroupMinWidth}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="GroupedSuccessButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource SuccessButtonStyle}">
        <Setter Property="Width" Value="{StaticResource ButtonGroupMinWidth}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="GroupedToolbarButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Width" Value="{StaticResource ButtonGroupMinWidth}" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="GroupedToolbarButtonWideStyle" TargetType="ui:Button" BasedOn="{StaticResource GroupedToolbarButtonStyle}">
        <Setter Property="Width" Value="{StaticResource ButtonGroupMinWidthWide}" />
    </Style>

    <Style x:Key="GroupedPrimaryButtonWideStyle" TargetType="ui:Button" BasedOn="{StaticResource GroupedPrimaryButtonStyle}">
        <Setter Property="Width" Value="{StaticResource ButtonGroupMinWidthWide}" />
    </Style>

    <Style x:Key="GroupedSecondaryButtonWideStyle" TargetType="ui:Button" BasedOn="{StaticResource GroupedSecondaryButtonStyle}">
        <Setter Property="Width" Value="{StaticResource ButtonGroupMinWidthWide}" />
    </Style>

    <Style x:Key="GroupedDangerButtonWideStyle" TargetType="ui:Button" BasedOn="{StaticResource GroupedDangerButtonStyle}">
        <Setter Property="Width" Value="{StaticResource ButtonGroupMinWidthWide}" />
    </Style>

    <Style x:Key="GroupedSecondaryButtonExtraWideStyle" TargetType="ui:Button" BasedOn="{StaticResource GroupedSecondaryButtonStyle}">
        <Setter Property="Width" Value="{StaticResource ButtonGroupMinWidthExtraWide}" />
    </Style>

    <Style x:Key="GroupedPrimaryButtonExtraWideStyle" TargetType="ui:Button" BasedOn="{StaticResource GroupedPrimaryButtonStyle}">
        <Setter Property="Width" Value="{StaticResource ButtonGroupMinWidthExtraWide}" />
    </Style>

    <Style x:Key="GroupedDangerButtonExtraWideStyle" TargetType="ui:Button" BasedOn="{StaticResource GroupedDangerButtonStyle}">
        <Setter Property="Width" Value="{StaticResource ButtonGroupMinWidthExtraWide}" />
    </Style>

    <Style x:Key="TabFilterButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource GroupedSecondaryButtonStyle}">
        <Setter Property="Width" Value="128" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

    <Style x:Key="DialogFooterButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource GroupedSecondaryButtonStyle}">
        <Setter Property="Width" Value="{x:Static sys:Double.NaN}" />
        <Setter Property="MinWidth" Value="100" />
        <Setter Property="Padding" Value="16,10" />
    </Style>

    <Style x:Key="DialogFooterPrimaryButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource GroupedPrimaryButtonStyle}">
        <Setter Property="Width" Value="{x:Static sys:Double.NaN}" />
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="Padding" Value="16,10" />
    </Style>

    <!-- ========== NAVIGATION ========== -->
    <Style x:Key="NavButtonStyle" TargetType="ui:Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Appearance" Value="Transparent" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrandNavHoverBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="NavButtonActiveStyle" TargetType="ui:Button" BasedOn="{StaticResource NavButtonStyle}">
        <Setter Property="Background" Value="{StaticResource BrandNavActiveBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource BrandPrimaryBrush}" />
    </Style>

    <!-- ========== SURFACES ========== -->
    <Style x:Key="AppCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrandSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="AppCardQuietStyle" TargetType="Border" BasedOn="{StaticResource AppCardStyle}">
        <Setter Property="Padding" Value="16" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style x:Key="ElevatedCardStyle" TargetType="Border" BasedOn="{StaticResource AppCardStyle}">
        <Setter Property="Padding" Value="28" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Effect" Value="{StaticResource ElevatedShadow}" />
    </Style>

    <Style x:Key="KpiCardStyle" TargetType="Border" BasedOn="{StaticResource AppCardStyle}">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,12,0" />
        <Setter Property="MinHeight" Value="112" />
    </Style>

    <Style x:Key="QuietSurfaceStyle" TargetType="Border" BasedOn="{StaticResource AppCardStyle}">
        <Setter Property="Padding" Value="24" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style x:Key="DsSurfaceCardStyle" TargetType="Border" BasedOn="{StaticResource AppCardStyle}" />

    <Style x:Key="DropZoneStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrandSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="40" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="IconBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style x:Key="IconBadgeLargeStyle" TargetType="Border" BasedOn="{StaticResource IconBadgeStyle}">
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="48" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <!-- ========== SHELL ========== -->
    <Style x:Key="SidebarPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrandSidebarBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Padding" Value="12,16" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="ToolbarPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrandBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="ContentHostStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrandBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="24,16,24,16" />
    </Style>

    <Style x:Key="StatusBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrandSidebarBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="16,8" />
    </Style>

    <Style x:Key="DialogFooterStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrandSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="24,16,24,20" />
    </Style>

    <Style x:Key="ActionTileStyle" TargetType="ui:Button" BasedOn="{StaticResource SecondaryButtonStyle}">
        <Setter Property="MinWidth" Value="140" />
        <Setter Property="MinHeight" Value="72" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>

    <Style x:Key="TransactionRowStyle" TargetType="Border">
        <Setter Property="Padding" Value="4,14" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ========== DATA GRID ========== -->
    <Style x:Key="AppDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource BrandElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Height" Value="40" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppDataGridCellStyle" TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter VerticalAlignment="Center"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource BrandNavActiveBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AppDataGridStyle" TargetType="DataGrid">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="RowBackground" Value="Transparent" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource BrandRowAltBrush}" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BrandBorderSubtleBrush}" />
        <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <Setter Property="CanUserResizeColumns" Value="True" />
        <Setter Property="CanUserSortColumns" Value="True" />
        <Setter Property="CanUserReorderColumns" Value="True" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="RowHeight" Value="44" />
        <Setter Property="ColumnHeaderHeight" Value="40" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource AppDataGridColumnHeaderStyle}" />
        <Setter Property="CellStyle" Value="{StaticResource AppDataGridCellStyle}" />
    </Style>

    <Style TargetType="{x:Type controls:AppDataGrid}" BasedOn="{StaticResource AppDataGridStyle}">
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource AppDataGridColumnHeaderStyle}" />
        <Setter Property="CellStyle" Value="{StaticResource AppDataGridCellStyle}" />
    </Style>

    <Style x:Key="AppSearchBoxStyle" TargetType="ui:TextBox">
        <Setter Property="MinWidth" Value="200" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="PlaceholderText" Value="Search…" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource BrandPrimaryBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource BrandAccentFillBrush}" />
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemChrome"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrandAccentFillBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrandNavActiveBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource BrandMutedTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="AppComboBoxToggleTemplate" TargetType="ToggleButton">
        <Border x:Name="Chrome"
                Background="{DynamicResource BrandSurfaceBrush}"
                BorderBrush="{DynamicResource BrandBorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="28" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1"
                           Text="▾"
                           FontSize="12"
                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource BrandElevatedBrush}" />
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BrandPrimaryBrush}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource BrandSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="MainGrid">
                        <ToggleButton x:Name="ToggleButton"
                                      Grid.ColumnSpan="2"
                                      Template="{StaticResource AppComboBoxToggleTemplate}"
                                      Focusable="False"
                                      ClickMode="Press"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />

                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Margin="10,0,30,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          RecognizesAccessKey="True"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}">
                            <ContentPresenter.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
                                    <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
                                    <Setter Property="FontSize" Value="14" />
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                </Style>
                            </ContentPresenter.Resources>
                        </ContentPresenter>

                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Grid x:Name="DropDown"
                                  SnapsToDevicePixels="True"
                                  MinWidth="{TemplateBinding ActualWidth}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border x:Name="DropDownBorder"
                                        Background="{DynamicResource BrandElevatedBrush}"
                                        BorderBrush="{DynamicResource BrandBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,4,0,0" />
                                <ScrollViewer Margin="4,8,4,8" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="DropDownBorder" Property="MinHeight" Value="48" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                        <Trigger Property="IsGrouping" Value="True">
                            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Calendar day cells: large and themed -->
    <Style x:Key="AppCalendarDayButtonStyle" TargetType="CalendarDayButton">
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarDayButton">
                    <Border x:Name="DayChrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Margin="2"
                            MinWidth="44"
                            MinHeight="44">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="DayChrome" Property="Background" Value="{DynamicResource BrandAccentFillBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="DayChrome" Property="Background" Value="{DynamicResource BrandPrimaryBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="DayChrome" Property="BorderBrush" Value="{DynamicResource BrandPrimaryBrush}" />
                            <Setter TargetName="DayChrome" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource BrandMutedTextBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppCalendarButtonStyle" TargetType="CalendarButton">
        <Setter Property="MinWidth" Value="112" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarButton">
                    <Border x:Name="BtnChrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Margin="2"
                            Padding="{TemplateBinding Padding}"
                            MinWidth="{TemplateBinding MinWidth}"
                            MinHeight="{TemplateBinding MinHeight}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnChrome" Property="Background" Value="{DynamicResource BrandAccentFillBrush}" />
                        </Trigger>
                        <Trigger Property="HasSelectedDays" Value="True">
                            <Setter TargetName="BtnChrome" Property="Background" Value="{DynamicResource BrandPrimaryBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource BrandMutedTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CalendarItem">
        <Setter Property="Background" Value="{DynamicResource BrandElevatedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="MinWidth" Value="340" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- Implicit styles so every calendar (including DatePicker popup) is themed and large -->
    <Style TargetType="CalendarDayButton" BasedOn="{StaticResource AppCalendarDayButtonStyle}" />
    <Style TargetType="CalendarButton" BasedOn="{StaticResource AppCalendarButtonStyle}" />

    <Style x:Key="AppCalendarStyle" TargetType="Calendar">
        <Setter Property="Background" Value="{DynamicResource BrandElevatedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="MinWidth" Value="340" />
        <Setter Property="MinHeight" Value="300" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="CalendarDayButtonStyle" Value="{StaticResource AppCalendarDayButtonStyle}" />
        <Setter Property="CalendarButtonStyle" Value="{StaticResource AppCalendarButtonStyle}" />
    </Style>

    <Style TargetType="Calendar" BasedOn="{StaticResource AppCalendarStyle}" />

    <!-- DatePicker text area: prevent vertical clipping in compact 40px fields -->
    <Style x:Key="AppDatePickerTextBoxStyle" TargetType="DatePickerTextBox">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
    </Style>

    <Style TargetType="DatePickerTextBox" BasedOn="{StaticResource AppDatePickerTextBoxStyle}" />

    <ControlTemplate x:Key="AppDatePickerTemplate" TargetType="DatePicker">
        <Border x:Name="Chrome"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="8"
                SnapsToDevicePixels="True">
            <Grid x:Name="PART_Root" VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="34" />
                </Grid.ColumnDefinitions>
                <DatePickerTextBox x:Name="PART_TextBox"
                                   Grid.Column="0"
                                   Margin="10,0,0,0"
                                   Style="{StaticResource AppDatePickerTextBoxStyle}"
                                   Focusable="{TemplateBinding Focusable}" />
                <Button x:Name="PART_Button"
                        Grid.Column="1"
                        Margin="0,1,1,1"
                        Width="32"
                        MinWidth="32"
                        Background="Transparent"
                        BorderThickness="0"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Center"
                        Focusable="False"
                        Cursor="Hand">
                    <TextBlock Text="&#xE787;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
                <Popup x:Name="PART_Popup"
                       AllowsTransparency="True"
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=Chrome}"
                       StaysOpen="False"
                       PopupAnimation="Fade"
                       VerticalOffset="4">
                    <Border Background="{DynamicResource BrandElevatedBrush}"
                            BorderBrush="{DynamicResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="4">
                        <Calendar Style="{TemplateBinding CalendarStyle}" BorderThickness="0" />
                    </Border>
                </Popup>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BrandPrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BrandPrimaryBrush}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style TargetType="DatePicker">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="{DynamicResource BrandSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="MinWidth" Value="180" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CalendarStyle" Value="{StaticResource AppCalendarStyle}" />
        <Setter Property="Template" Value="{StaticResource AppDatePickerTemplate}" />
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{DynamicResource BrandSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderSubtleBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource BrandPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
        <Setter Property="Background" Value="{DynamicResource BrandSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderSubtleBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource BrandPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- ========== PAGE ENTRANCE ========== -->
    <Style x:Key="PageRootStyle" TargetType="UserControl">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform Y="6" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0" To="1"
                                         Duration="0:0:0.18"
                                         AccelerationRatio="0.1"
                                         DecelerationRatio="0.7" />
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                         From="6" To="0"
                                         Duration="0:0:0.18"
                                         AccelerationRatio="0.1"
                                         DecelerationRatio="0.7" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
