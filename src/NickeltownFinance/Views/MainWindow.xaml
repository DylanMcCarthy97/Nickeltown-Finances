<ui:FluentWindow x:Class="NickeltownFinance.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:ds="clr-namespace:NickeltownFinance.Controls"
                 Title="{Binding WindowTitle}"
                 MinWidth="1024" MinHeight="680"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Background="{DynamicResource BrandBackgroundBrush}"
                 Icon="pack://application:,,,/Assets/AppIcon.png"
                 FontFamily="{StaticResource AppFontFamily}">
    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewTransactionCommand}" />
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding FocusSearchCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding BackupCommand}" />
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoDeleteCommand}" />
        <KeyBinding Key="B" Modifiers="Control" Command="{Binding ToggleSidebarCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </ui:FluentWindow.InputBindings>

    <Grid Background="{DynamicResource BrandBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="{Binding WindowTitle}"
                     Grid.Row="0"
                     Background="{DynamicResource BrandBackgroundBrush}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon.png" Width="16" Height="16" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SidebarWidth}" MinWidth="64" MaxWidth="220" />
                <ColumnDefinition Width="*" MinWidth="480" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar — five sections only -->
            <Border Grid.Column="0" Style="{StaticResource SidebarPanelStyle}">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                        <Grid Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Image Source="{Binding ClubLogoImage}"
                                   Width="28" Height="28"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"
                                   Margin="4,0,10,0"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Nickeltown Finance"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandTextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding ClubName}"
                                           FontSize="11"
                                           Foreground="{StaticResource BrandMutedTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                            <ui:Button Grid.Column="2"
                                       Icon="{ui:SymbolIcon Navigation24}"
                                       Style="{StaticResource ToolbarButtonStyle}"
                                       ToolTip="Collapse sidebar (Ctrl+B)"
                                       Command="{Binding ToggleSidebarCommand}" />
                        </Grid>

                        <ui:Button HorizontalAlignment="Center"
                                   Icon="{ui:SymbolIcon Navigation24}"
                                   Style="{StaticResource ToolbarButtonStyle}"
                                   ToolTip="Expand sidebar (Ctrl+B)"
                                   Command="{Binding ToggleSidebarCommand}"
                                   Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                        <ui:Button Content="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarLabelConverter}, ConverterParameter=Backup}"
                                   Icon="{ui:SymbolIcon ArrowDownload24}"
                                   Style="{StaticResource NavButtonStyle}"
                                   ToolTip="Backup now (Ctrl+S)"
                                   Command="{Binding BackupCommand}"
                                   Margin="0,0,0,8" />

                        <ui:Button Content="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarLabelConverter}, ConverterParameter=Sign out}"
                                   Icon="{ui:SymbolIcon SignOut24}"
                                   Style="{StaticResource NavButtonStyle}"
                                   ToolTip="Sign out and switch user"
                                   Command="{Binding SignOutCommand}"
                                   Margin="0,0,0,8" />

                        <Border Padding="10,12"
                                CornerRadius="12"
                                Background="{StaticResource BrandInsetBrush}"
                                Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding UserDisplayName}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandTextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding UserRoleDisplay}"
                                           FontSize="11"
                                           Foreground="{StaticResource BrandMutedTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <ui:Button Content="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarLabelConverter}, ConverterParameter=Dashboard}"
                                       Icon="{ui:SymbolIcon Home24}" ToolTip="Dashboard"
                                       Command="{Binding NavigateDashboardCommand}">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource NavButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveNavKey}" Value="Dashboard">
                                                <Setter Property="Background" Value="{StaticResource BrandNavActiveBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Foreground" Value="{StaticResource BrandPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>

                            <ui:Button Content="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarLabelConverter}, ConverterParameter=Transactions}"
                                       Icon="{ui:SymbolIcon List24}" ToolTip="Transactions"
                                       Command="{Binding NavigateTransactionsCommand}">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource NavButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveNavKey}" Value="Transactions">
                                                <Setter Property="Background" Value="{StaticResource BrandNavActiveBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Foreground" Value="{StaticResource BrandPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>

                            <ui:Button Content="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarLabelConverter}, ConverterParameter=Imports}"
                                       Icon="{ui:SymbolIcon ArrowUpload24}" ToolTip="Imports"
                                       Command="{Binding NavigateImportsCommand}">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource NavButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveNavKey}" Value="Imports">
                                                <Setter Property="Background" Value="{StaticResource BrandNavActiveBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Foreground" Value="{StaticResource BrandPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>

                            <ui:Button Content="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarLabelConverter}, ConverterParameter=Reports}"
                                       Icon="{ui:SymbolIcon DataBarVertical24}" ToolTip="Reports"
                                       Command="{Binding NavigateReportsCommand}">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource NavButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveNavKey}" Value="Reports">
                                                <Setter Property="Background" Value="{StaticResource BrandNavActiveBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Foreground" Value="{StaticResource BrandPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>

                            <ui:Button Content="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarLabelConverter}, ConverterParameter=Financial Years}"
                                       Icon="{ui:SymbolIcon CalendarLtr24}" ToolTip="Financial Years"
                                       Command="{Binding NavigateFinancialYearsCommand}">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource NavButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveNavKey}" Value="FinancialYears">
                                                <Setter Property="Background" Value="{StaticResource BrandNavActiveBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Foreground" Value="{StaticResource BrandPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>

                            <ui:Button Content="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarLabelConverter}, ConverterParameter=Settings}"
                                       Icon="{ui:SymbolIcon Settings24}" ToolTip="Settings"
                                       Command="{Binding NavigateSettingsCommand}">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource NavButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveNavKey}" Value="Settings">
                                                <Setter Property="Background" Value="{StaticResource BrandNavActiveBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Foreground" Value="{StaticResource BrandPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Main -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ToolbarPanelStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="160" MaxWidth="360" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ds:SearchBar Placeholder="Search transactions… (Ctrl+F)"
                                      Text="{Binding GlobalSearchText, UpdateSourceTrigger=PropertyChanged}"
                                      SearchCommand="{Binding GlobalSearchCommand}"
                                      ShowButton="False"
                                      TextBoxMargin="0" />

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <ComboBox ItemsSource="{Binding FinancialYears}"
                                      SelectedItem="{Binding SelectedFinancialYear}"
                                      DisplayMemberPath="Name"
                                      MinWidth="120"
                                      Margin="0,0,12,0"
                                      VerticalAlignment="Center"
                                      ToolTip="Financial year" />

                            <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                                <Border Width="28" Height="28"
                                        CornerRadius="14"
                                        Background="{StaticResource BrandAccentFillBrush}"
                                        Margin="0,0,8,0">
                                    <ui:SymbolIcon Symbol="Person24"
                                                   FontSize="14"
                                                   Foreground="{StaticResource BrandPrimaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding UserDisplayName}"
                                               FontSize="13"
                                               FontWeight="Medium"
                                               Foreground="{StaticResource BrandTextSecondaryBrush}"
                                               MaxWidth="140"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding UserRoleDisplay}"
                                               FontSize="11"
                                               Foreground="{StaticResource BrandMutedTextBrush}"
                                               MaxWidth="140"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <ui:Button Icon="{ui:SymbolIcon SignOut24}"
                                           Style="{StaticResource ToolbarButtonStyle}"
                                           ToolTip="Sign out and switch user"
                                           Command="{Binding SignOutCommand}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource ContentHostStyle}">
                    <Grid>
                        <ContentControl Content="{Binding CurrentPage}"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch" />
                        <ds:SuccessNotificationHost x:Name="NotificationHost" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource StatusBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="80" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="7" Height="7"
                             Fill="{StaticResource BrandSuccessBrush}"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0" />
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12"
                               Foreground="{StaticResource BrandTextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding FinancialYearStatus}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrandPrimaryBrush}"
                           Margin="16,0"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="2"
                           Text="{Binding UserDisplayName}"
                           FontSize="12"
                           Foreground="{StaticResource BrandMutedTextBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
