<UserControl x:Class="NickeltownFinance.Views.Pages.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:views="clr-namespace:NickeltownFinance.Views.Pages"
             Style="{StaticResource PageRootStyle}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Reports" Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="Professional club reports — one click to generate, export, or print."
                       Style="{StaticResource PageSubtitleStyle}" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource BrandInsetBrush}"
                CornerRadius="12"
                Padding="4"
                HorizontalAlignment="Left"
                Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <ui:Button Content="Monthly report"
                           Icon="{ui:SymbolIcon CalendarLtr24}"
                           Margin="0,0,4,0"
                           Command="{Binding ShowMonthlyCommand}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource SegmentedTabButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                                    <Setter Property="Background" Value="{StaticResource BrandSurfaceBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource BrandPrimaryBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Content="AGM / Year report"
                           Icon="{ui:SymbolIcon DocumentOnePage24}"
                           Command="{Binding ShowAgmCommand}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource SegmentedTabButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                    <Setter Property="Background" Value="{StaticResource BrandSurfaceBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource BrandPrimaryBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <ContentControl Content="{Binding MonthlyReport}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
            <ContentControl Content="{Binding AgmReport}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>
    </Grid>
</UserControl>
