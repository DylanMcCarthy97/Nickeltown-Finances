<UserControl x:Class="NickeltownFinance.Views.Pages.MonthlyReportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ds="clr-namespace:NickeltownFinance.Controls"
             Style="{StaticResource PageRootStyle}">
    <ds:PageShell IsBusy="{Binding IsBusy}" ErrorMessage="{Binding ErrorMessage}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <ds:SurfaceCard CardMargin="0,0,0,16">
                    <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="140" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" MinWidth="120" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" MinWidth="100" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="1.4*" MinWidth="160" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Financial year" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox ItemsSource="{Binding FinancialYears}" SelectedItem="{Binding SelectedFinancialYear}" DisplayMemberPath="Name" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Month" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource MonthNameConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Year" Style="{StaticResource FieldLabelStyle}" />
                            <ui:NumberBox Value="{Binding SelectedYear}" Minimum="2000" Maximum="2100" SpinButtonPlacementMode="Hidden" />
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="Notes" Style="{StaticResource FieldLabelStyle}" />
                            <ui:TextBox Text="{Binding Notes}" PlaceholderText="Optional notes for the report" />
                        </StackPanel>
                        <ui:Button Grid.Column="8" Content="Preview"
                                   Style="{StaticResource PrimaryButtonStyle}"
                                   Icon="{ui:SymbolIcon Eye24}"
                                   VerticalAlignment="Bottom"
                                   Command="{Binding GenerateReportCommand}" />
                    </Grid>
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="120" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" MinWidth="120" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Cash on hand (petty cash)" Style="{StaticResource FieldLabelStyle}" />
                            <ui:NumberBox Value="{Binding CashOnHand}" Minimum="0" SpinButtonPlacementMode="Hidden" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Bonds with the Shire" Style="{StaticResource FieldLabelStyle}" />
                            <ui:NumberBox Value="{Binding ShireBonds}" Minimum="0" SpinButtonPlacementMode="Hidden" />
                        </StackPanel>
                    </Grid>
                    </StackPanel>
                </ds:SurfaceCard>

                <ds:SurfaceCard CardMargin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Pitstop reports" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Attach ClubPOS end-of-day reports when this month had a Pitstop event."
                                           Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <ui:Button Grid.Column="1"
                                       Content="Attach report"
                                       Style="{StaticResource SecondaryButtonStyle}"
                                       Icon="{ui:SymbolIcon Attach24}"
                                       VerticalAlignment="Top"
                                       Command="{Binding AttachPitstopReportCommand}" />
                        </Grid>

                        <TextBlock Text="No Pitstop reports attached for this month."
                                   Style="{StaticResource CaptionTextStyle}"
                                   Visibility="{Binding HasPitstopReports, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                        <ItemsControl ItemsSource="{Binding PitstopReports}"
                                      Visibility="{Binding HasPitstopReports, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource AppCardStyle}" Padding="12" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayLabel}" FontWeight="SemiBold" />
                                                <TextBlock Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,0">
                                                    <Run Text="{Binding FileName, Mode=OneWay}" />
                                                    <Run Text="  ·  " />
                                                    <Run Text="{Binding SizeDisplay, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <ui:Button Content="View"
                                                           Style="{StaticResource GroupedSecondaryButtonStyle}"
                                                           Margin="{StaticResource ButtonGroupMarginInline}"
                                                           Command="{Binding DataContext.OpenPitstopReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           CommandParameter="{Binding}" />
                                                <ui:Button Content="Open file"
                                                           Style="{StaticResource GroupedSecondaryButtonStyle}"
                                                           Margin="{StaticResource ButtonGroupMarginInline}"
                                                           Command="{Binding DataContext.OpenPitstopReportExternallyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           CommandParameter="{Binding}" />
                                                <ui:Button Content="Remove"
                                                           Style="{StaticResource GroupedSecondaryButtonStyle}"
                                                           Command="{Binding DataContext.RemovePitstopReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ds:SurfaceCard>

                <ds:EmptyState Title="No report yet"
                               Message="Choose a financial year and month, then click Preview to generate your monthly treasurer report."
                               IconSymbol="DocumentSearch24"
                               Margin="0,8,0,0"
                               Visibility="{Binding HasReport, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <ds:EmptyState.ActionContent>
                        <ui:Button Content="Preview report"
                                   Style="{StaticResource PrimaryButtonStyle}"
                                   Icon="{ui:SymbolIcon Eye24}"
                                   Command="{Binding GenerateReportCommand}" />
                    </ds:EmptyState.ActionContent>
                </ds:EmptyState>

                <StackPanel Style="{StaticResource RevealPanelStyle}"
                            Visibility="{Binding HasReport, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ds:SurfaceCard CardMargin="0,0,0,14" CardPadding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="Print" Icon="{ui:SymbolIcon Print24}" Style="{StaticResource GroupedSecondaryButtonStyle}" Margin="{StaticResource ButtonGroupMarginInline}" Command="{Binding PrintCommand}" />
                            <ui:Button Content="Export PDF" Icon="{ui:SymbolIcon DocumentPdf24}" Style="{StaticResource GroupedSecondaryButtonStyle}" Margin="{StaticResource ButtonGroupMarginInline}" Command="{Binding ExportPdfCommand}" />
                            <ui:Button Content="Export Excel" Icon="{ui:SymbolIcon Table24}" Style="{StaticResource GroupedSecondaryButtonStyle}" Command="{Binding ExportExcelCommand}" />
                        </StackPanel>
                    </ds:SurfaceCard>

                    <ds:ReportCard ClubName="{Binding ReportData.ClubName}"
                                   ReportTitle="Monthly Treasurer Report"
                                   MaxWidth="960"
                                   HorizontalAlignment="Center">
                        <ds:ReportCard.Subtitle>
                            <MultiBinding StringFormat="{}{0} {1}  ·  FY {2}">
                                <Binding Path="ReportData.MonthName" />
                                <Binding Path="ReportData.Year" />
                                <Binding Path="ReportData.FinancialYearName" />
                            </MultiBinding>
                        </ds:ReportCard.Subtitle>
                        <StackPanel DataContext="{Binding ReportData}">
                            <TextBlock Margin="0,0,0,16" TextWrapping="Wrap"
                                       Style="{StaticResource CaptionTextStyle}">
                                <Run Text="Signed by " />
                                <Run Text="{Binding PreparedBy, Mode=OneWay}" FontWeight="SemiBold" />
                                <Run Text=" (" />
                                <Run Text="{Binding PreparedByRole, Mode=OneWay}" />
                                <Run Text=")  ·  " />
                                <Run Text="{Binding PrintedAtDisplay, Mode=OneWay}" />
                            </TextBlock>

                            <UniformGrid Columns="4" Margin="0,0,0,18">
                                <ds:MoneyCard Title="Opening balance" Amount="{Binding OpeningBalance}" Tone="Neutral" ShowIcon="False" Margin="0,0,8,0" />
                                <ds:MoneyCard Title="Income" Amount="{Binding TotalIncome}" Tone="Income" ShowIcon="False" Margin="0,0,8,0" />
                                <ds:MoneyCard Title="Expenses" Amount="{Binding TotalExpenses}" Tone="Expense" ShowIcon="False" Margin="0,0,8,0" />
                                <ds:MoneyCard Title="{Binding ClosingBalanceTitle}" Amount="{Binding ClosingBalance}" Tone="Neutral" ShowIcon="False" />
                            </UniformGrid>

                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ds:StatisticCard Title="Income by category">
                                    <StackPanel>
                                        <ItemsControl ItemsSource="{Binding IncomeByCategory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <ds:ReportLine Label="{Binding CategoryName}" Amount="{Binding Amount}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ds:ReportLine Label="Total income" Amount="{Binding TotalIncome}" IsBold="True" LineMargin="0,12,0,0" />
                                    </StackPanel>
                                </ds:StatisticCard>

                                <ds:StatisticCard Grid.Column="2" Title="Expenses by category">
                                    <StackPanel>
                                        <ItemsControl ItemsSource="{Binding ExpensesByCategory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <ds:ReportLine Label="{Binding CategoryName}" Amount="{Binding Amount}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ds:ReportLine Label="Total expenses" Amount="{Binding TotalExpenses}" IsBold="True" LineMargin="0,12,0,0" />
                                    </StackPanel>
                                </ds:StatisticCard>
                            </Grid>

                            <ds:MoneyCard Title="Monthly profit / loss" Amount="{Binding MonthlyProfit}" Tone="Profit"
                                          ShowIcon="False" Margin="0,0,0,20" />

                            <TextBlock Text="Treasurer comments" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8" />
                            <Border Style="{StaticResource AppCardStyle}" Padding="16" Margin="0,0,0,20">
                                <StackPanel>
                                    <ds:ReportLine Label="Cash on hand (petty cash)" Amount="{Binding CashOnHand}" />
                                    <ds:ReportLine Label="Bonds with the Shire" Amount="{Binding ShireBonds}" />
                                    <ds:ReportLine Label="Total moneys owned by the club" Amount="{Binding TotalFundsOwned}" IsBold="True" LineMargin="0,10,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource AppCardStyle}" Padding="16" Margin="0,0,0,20"
                                    Visibility="{Binding SquareBreakdown, Converter={StaticResource EmptyCollectionToVisibilityConverter}, ConverterParameter=Invert}">
                                <StackPanel>
                                    <TextBlock Text="Square transfer breakdown" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,4" />
                                    <TextBlock Text="What made up the matched Square deposits this month — bar top-ups, memberships, and Pitstop sales."
                                               Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,12" />

                                    <ItemsControl ItemsSource="{Binding SquareBreakdown}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,14">
                                                    <TextBlock Text="{Binding SectionName}" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,6" />
                                                    <ItemsControl ItemsSource="{Binding Items}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <ds:ReportLine Label="{Binding Label}" Amount="{Binding Amount}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <ds:ReportLine Label="Section total" Amount="{Binding SectionTotal}" IsBold="True" LineMargin="0,8,0,0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource AppCardStyle}" Padding="16" Margin="0,0,0,20"
                                    Visibility="{Binding PitstopReports, Converter={StaticResource EmptyCollectionToVisibilityConverter}, ConverterParameter=Invert}">
                                <StackPanel>
                                    <TextBlock Text="Pitstop event reports" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,4" />
                                    <TextBlock Text="ClubPOS end-of-day reports attached to this month."
                                               Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,12" />

                                    <ItemsControl ItemsSource="{Binding PitstopReports}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,0,0,6" TextWrapping="Wrap">
                                                    <Run Text="• " />
                                                    <Run Text="{Binding DisplayLabel, Mode=OneWay}" FontWeight="SemiBold" />
                                                    <Run Text=" (" />
                                                    <Run Text="{Binding FileName, Mode=OneWay}" />
                                                    <Run Text=")" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Bank transactions" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,4" />
                            <TextBlock Text="As shown on the ANZ statement, with the category assigned in Nickeltown Finance."
                                       Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,10" />

                            <Border Style="{StaticResource AppCardStyle}" Padding="0" Margin="0,0,0,20">
                                <Grid>
                                    <TextBlock Text="No transactions this month"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Margin="16"
                                               Visibility="{Binding Transactions, Converter={StaticResource EmptyCollectionToVisibilityConverter}}" />

                                    <ds:AppDataGrid ItemsSource="{Binding Transactions}"
                                                    Visibility="{Binding Transactions, Converter={StaticResource EmptyCollectionToVisibilityConverter}, ConverterParameter=Invert}">
                                        <ds:AppDataGrid.Columns>
                                            <DataGridTextColumn Header="Date"
                                                                Binding="{Binding Date, StringFormat=dd/MM/yyyy}"
                                                                Width="88" />
                                            <DataGridTextColumn Header="Bank description (ANZ)"
                                                                Binding="{Binding Description}"
                                                                Width="*"
                                                                MinWidth="160" />
                                            <DataGridTextColumn Header="Category"
                                                                Binding="{Binding CategoryName}"
                                                                Width="120" />
                                            <DataGridTextColumn Header="Money in"
                                                                Binding="{Binding MoneyInDisplay}"
                                                                Width="90" />
                                            <DataGridTextColumn Header="Money out"
                                                                Binding="{Binding MoneyOutDisplay}"
                                                                Width="90" />
                                        </ds:AppDataGrid.Columns>
                                    </ds:AppDataGrid>
                                </Grid>
                            </Border>

                            <ds:TreasurerDeclarationCard DeclarationText="I confirm this report is a true and fair summary of the club's bank transactions for the period." />
                        </StackPanel>
                    </ds:ReportCard>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </ds:PageShell>
</UserControl>
