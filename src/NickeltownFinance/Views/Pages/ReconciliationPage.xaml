<UserControl x:Class="NickeltownFinance.Views.Pages.ReconciliationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ds="clr-namespace:NickeltownFinance.Controls"
             Style="{StaticResource PageRootStyle}">
    <ds:PageShell IsBusy="{Binding IsBusy}" ErrorMessage="{Binding ErrorMessage}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Reconciliation" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="Square deposits are matched to ANZ transfers automatically. Resolve anything that needs review here."
                               Style="{StaticResource PageSubtitleStyle}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}"
                               Style="{StaticResource GroupedSecondaryButtonWideStyle}"
                               Command="{Binding RefreshCommand}" Margin="{StaticResource ButtonGroupMarginInline}" />
                    <ui:Button Content="Back to Imports" Style="{StaticResource GroupedSecondaryButtonWideStyle}"
                               Command="{Binding BackToImportsCommand}" />
                </StackPanel>
            </Grid>

            <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,16">
                <Border Style="{StaticResource AppCardStyle}" Padding="16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Bank Deposits" Style="{StaticResource DetailLabelStyle}" />
                        <TextBlock Text="{Binding BankDeposits}" FontSize="28" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource AppCardStyle}" Padding="16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Matched" Style="{StaticResource DetailLabelStyle}" />
                        <TextBlock Text="{Binding Matched}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandIncomeBrush}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource AppCardStyle}" Padding="16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Needs Review" Style="{StaticResource DetailLabelStyle}" />
                        <TextBlock Text="{Binding NeedsReview}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandWarningBrush}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource AppCardStyle}" Padding="16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Import Errors" Style="{StaticResource DetailLabelStyle}" />
                        <TextBlock Text="{Binding ImportErrors}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandExpenseBrush}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource AppCardStyle}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Reconciled Total" Style="{StaticResource DetailLabelStyle}" />
                        <TextBlock Text="{Binding ReconciledTotal, StringFormat=C}" FontSize="24" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandIncomeBrush}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">
                <TabItem Header="Needs review">
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource AppCardStyle}" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="ANZ deposit" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8" />
                                <ds:AppDataGrid Grid.Row="1"
                                                ItemsSource="{Binding ManualReviewItems}"
                                                SelectedItem="{Binding SelectedReviewItem}">
                                    <ds:AppDataGrid.Columns>
                                        <DataGridTextColumn Header="Date" Binding="{Binding AnzDeposit.Date, StringFormat=dd/MM/yyyy}" Width="95" />
                                        <DataGridTextColumn Header="Description" Binding="{Binding AnzDeposit.Description}" Width="*" />
                                        <DataGridTextColumn Header="Amount" Binding="{Binding AnzDeposit.Amount, StringFormat=C}" Width="100" />
                                    </ds:AppDataGrid.Columns>
                                </ds:AppDataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource AppCardStyle}" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Possible Square deposits" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8" />
                                <ds:AppDataGrid Grid.Row="1"
                                                ItemsSource="{Binding SelectedReviewItem.PossibleSquareDeposits}"
                                                SelectedItem="{Binding SelectedSquareCandidate}">
                                    <ds:AppDataGrid.Columns>
                                        <DataGridTextColumn Header="Date" Binding="{Binding DepositDate, StringFormat=dd/MM/yyyy}" Width="95" />
                                        <DataGridTextColumn Header="Deposit ID" Binding="{Binding DepositId}" Width="*" />
                                        <DataGridTextColumn Header="Net" Binding="{Binding NetAmount, StringFormat=C}" Width="100" />
                                        <DataGridTextColumn Header="Txns" Binding="{Binding TransactionCount}" Width="60" />
                                    </ds:AppDataGrid.Columns>
                                </ds:AppDataGrid>
                            </Grid>
                        </Border>

                        <ui:Button Grid.Row="1" Grid.ColumnSpan="3"
                                   Content="Match selected" Icon="{ui:SymbolIcon Checkmark24}"
                                   Style="{StaticResource PrimaryButtonStyle}"
                                   HorizontalAlignment="Right" Margin="0,12,0,0"
                                   Command="{Binding ConfirmMatchCommand}" />
                    </Grid>
                </TabItem>

                <TabItem Header="Matched">
                    <ds:AppDataGrid Margin="0,14,0,0" ItemsSource="{Binding MatchedDeposits}">
                        <ds:AppDataGrid.Columns>
                            <DataGridTextColumn Header="Bank date" Binding="{Binding BankDate, StringFormat=dd/MM/yyyy}" Width="100" />
                            <DataGridTextColumn Header="Deposit date" Binding="{Binding DepositDate, StringFormat=dd/MM/yyyy}" Width="110" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="Deposit ID" Binding="{Binding DepositId}" Width="140" />
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=C}" Width="110" />
                        </ds:AppDataGrid.Columns>
                    </ds:AppDataGrid>
                </TabItem>

                <TabItem Header="Unmatched ANZ">
                    <ds:AppDataGrid Margin="0,14,0,0" ItemsSource="{Binding UnmatchedAnzDeposits}">
                        <ds:AppDataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=dd/MM/yyyy}" Width="100" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=C}" Width="110" />
                            <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="140" />
                        </ds:AppDataGrid.Columns>
                    </ds:AppDataGrid>
                </TabItem>

                <TabItem Header="Unmatched Square">
                    <ds:AppDataGrid Margin="0,14,0,0" ItemsSource="{Binding UnmatchedSquareDeposits}">
                        <ds:AppDataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding DepositDate, StringFormat=dd/MM/yyyy}" Width="100" />
                            <DataGridTextColumn Header="Deposit ID" Binding="{Binding DepositId}" Width="*" />
                            <DataGridTextColumn Header="Gross" Binding="{Binding GrossAmount, StringFormat=C}" Width="100" />
                            <DataGridTextColumn Header="Fees" Binding="{Binding Fees, StringFormat=C}" Width="90" />
                            <DataGridTextColumn Header="Net" Binding="{Binding NetAmount, StringFormat=C}" Width="100" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                        </ds:AppDataGrid.Columns>
                    </ds:AppDataGrid>
                </TabItem>
            </TabControl>
        </Grid>
    </ds:PageShell>
</UserControl>
