<UserControl x:Class="NickeltownFinance.Views.Pages.TransactionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ds="clr-namespace:NickeltownFinance.Controls"
             xmlns:vm="clr-namespace:NickeltownFinance.ViewModels"
             Style="{StaticResource PageRootStyle}">
    <UserControl.InputBindings>
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding ExportCommand}" />
        <KeyBinding Key="P" Modifiers="Control" Command="{Binding PrintCommand}" />
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoDeleteCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </UserControl.InputBindings>

    <ds:PageShell IsBusy="{Binding IsBusy}" ErrorMessage="{Binding ErrorMessage}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Transactions" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Style="{StaticResource PageSubtitleStyle}">
                        <Run Text="FY " />
                        <Run Text="{Binding FinancialYearLabel, Mode=OneWay}" />
                        <Run Text=" — search, filter, and manage club income and expenses." />
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Content="Import statement"
                               Style="{StaticResource SecondaryButtonStyle}"
                               Margin="{StaticResource ButtonGroupMarginInline}"
                               Icon="{ui:SymbolIcon ArrowUpload24}"
                               Command="{Binding ImportStatementCommand}" />
                    <ui:Button Content="Add transaction"
                               Style="{StaticResource PrimaryButtonStyle}"
                               Icon="{ui:SymbolIcon Add24}"
                               Command="{Binding AddTransactionCommand}" />
                </StackPanel>
            </Grid>

            <ds:SurfaceCard Grid.Row="1" Title="Filters" CardMargin="0,0,0,16" CardPadding="20">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" MinWidth="140" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" MinWidth="100" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" MinWidth="90" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" MinWidth="90" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Search" Style="{StaticResource FieldLabelStyle}" />
                            <ds:SearchBar Placeholder="Description, amount, date, invoice, ABN…"
                                          Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                          ShowButton="False" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Category" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding SelectedCategoryFilter}"
                                      DisplayMemberPath="Name" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Type" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox ItemsSource="{Binding TypeFilterOptions}"
                                      SelectedItem="{Binding TypeFilter}" />
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="Receipts" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox ItemsSource="{Binding ReceiptFilterOptions}"
                                      SelectedItem="{Binding ReceiptFilter}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="From" Style="{StaticResource FieldLabelStyle}" />
                                <ds:AppDateField SelectedDate="{Binding FromDate}" MinWidth="140" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="To" Style="{StaticResource FieldLabelStyle}" />
                                <ds:AppDateField SelectedDate="{Binding ToDate}" MinWidth="140" />
                            </StackPanel>
                        </StackPanel>

                        <ui:Button Grid.Column="2"
                                   Content="Clear filters"
                                   Style="{StaticResource SecondaryButtonStyle}"
                                   VerticalAlignment="Bottom"
                                   Command="{Binding ClearFilterCommand}" />

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <ui:Button Content="Undo" Icon="{ui:SymbolIcon ArrowUndo24}"
                                       Style="{StaticResource GroupedToolbarButtonStyle}"
                                       Command="{Binding UndoDeleteCommand}" Margin="0,0,4,0" ToolTip="Ctrl+Z" />
                            <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}"
                                       Style="{StaticResource GroupedToolbarButtonStyle}"
                                       Command="{Binding RefreshCommand}" Margin="0,0,4,0" ToolTip="F5" />
                            <ui:Button Content="Export" Icon="{ui:SymbolIcon ArrowDownload24}"
                                       Style="{StaticResource GroupedToolbarButtonStyle}"
                                       Command="{Binding ExportCommand}" Margin="0,0,4,0" ToolTip="Ctrl+E" />
                            <ui:Button Content="Edit" Icon="{ui:SymbolIcon Edit24}"
                                       Style="{StaticResource GroupedToolbarButtonStyle}"
                                       Command="{Binding EditTransactionCommand}" Margin="0,0,4,0" />
                            <ui:Button Content="Receipts" Icon="{ui:SymbolIcon Receipt24}"
                                       Style="{StaticResource GroupedToolbarButtonStyle}"
                                       Command="{Binding ViewReceiptsCommand}" Margin="0,0,4,0" />
                            <ui:Button Content="Duplicate" Icon="{ui:SymbolIcon Copy24}"
                                       Style="{StaticResource GroupedToolbarButtonStyle}"
                                       Command="{Binding DuplicateTransactionCommand}" Margin="0,0,4,0" />
                            <ui:Button Content="Delete" Icon="{ui:SymbolIcon Delete24}"
                                       Style="{StaticResource GroupedDangerButtonStyle}"
                                       Command="{Binding DeleteTransactionCommand}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ds:SurfaceCard>

            <ds:SurfaceCard Grid.Row="2" CardMargin="0" CardPadding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="280" />
                        <ColumnDefinition Width="{Binding ShowDetailPanel, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=12}" />
                        <ColumnDefinition Width="{Binding ShowDetailPanel, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=380}" />
                    </Grid.ColumnDefinitions>

                    <ds:AppDataGrid Grid.Column="0" ItemsSource="{Binding Transactions}"
                                    SelectedItem="{Binding SelectedTransaction}"
                                    LayoutKey="Transactions"
                                    CanUserSortColumns="True"
                                    AllowDrop="True"
                                    PreviewDragOver="TransactionsGrid_OnPreviewDragOver"
                                    Drop="TransactionsGrid_OnDrop"
                                    MouseDoubleClick="DataGrid_OnMouseDoubleClick"
                                    Visibility="{Binding Transactions, Converter={StaticResource EmptyCollectionToVisibilityConverter}, ConverterParameter=Invert}">
                        <ds:AppDataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Edit" Command="{Binding EditTransactionCommand}" />
                                <MenuItem Header="View receipts" Command="{Binding ViewReceiptsCommand}" />
                                <MenuItem Header="Duplicate" Command="{Binding DuplicateTransactionCommand}" />
                                <MenuItem Header="Delete" Command="{Binding DeleteTransactionCommand}" />
                                <Separator />
                                <MenuItem Header="Export" Command="{Binding ExportCommand}" />
                                <MenuItem Header="Undo delete" Command="{Binding UndoDeleteCommand}" />
                            </ContextMenu>
                        </ds:AppDataGrid.ContextMenu>
                        <ds:AppDataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="72">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <ui:Button Icon="{ui:SymbolIcon Attach24}"
                                                       ToolTip="View receipts"
                                                       Style="{StaticResource ToolbarButtonStyle}"
                                                       Visibility="{Binding HasReceipt, Converter={StaticResource BoolToVisibilityConverter}}"
                                                       Click="ReceiptIcon_OnClick"
                                                       Padding="2" Margin="0,0,2,0" />
                                            <ui:Button Icon="{ui:SymbolIcon Payment24}"
                                                       ToolTip="{Binding SquareStatusToolTip}"
                                                       Style="{StaticResource ToolbarButtonStyle}"
                                                       Visibility="{Binding HasSquareDepositDetail, Converter={StaticResource BoolToVisibilityConverter}}"
                                                       Padding="2" Margin="0,0,2,0"
                                                       Foreground="{StaticResource BrandSuccessBrush}" />
                                            <ui:Button Icon="{ui:SymbolIcon Clock24}"
                                                       ToolTip="{Binding SquareStatusToolTip}"
                                                       Style="{StaticResource ToolbarButtonStyle}"
                                                       Visibility="{Binding IsSquareAwaitingMatch, Converter={StaticResource BoolToVisibilityConverter}}"
                                                       Padding="2"
                                                       Foreground="{StaticResource BrandWarningBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Receipt" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ds:StatusBadge Text="Required"
                                                        Tone="Warning"
                                                        Visibility="{Binding ReceiptRequired, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=dd/MM/yyyy}" Width="95" SortMemberPath="Date" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" SortMemberPath="Description" />
                            <DataGridTemplateColumn Header="Square" Width="88" SortMemberPath="IsSquareDeposit">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <ds:StatusBadge Text="Matched"
                                                            Tone="Success"
                                                            Visibility="{Binding HasSquareDepositDetail, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <ds:StatusBadge Text="Awaiting"
                                                            Tone="Warning"
                                                            Visibility="{Binding IsSquareAwaitingMatch, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="110" SortMemberPath="CategoryName" />
                            <DataGridTemplateColumn Header="Income" Width="90" SortMemberPath="IncomeAmount">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IncomeAmount, Converter={StaticResource ZeroToDashConverter}}"
                                                   Foreground="{StaticResource BrandIncomeBrush}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Expense" Width="90" SortMemberPath="ExpenseAmount">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ExpenseAmount, Converter={StaticResource ZeroToDashConverter}}"
                                                   Foreground="{StaticResource BrandExpenseBrush}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Balance" Width="110" SortMemberPath="RunningBalance">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RunningBalance, Converter={StaticResource CurrencyConverter}}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Payment" Binding="{Binding PaymentMethod}" Width="90" />
                            <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="90" />
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="110" />
                            <DataGridTextColumn Header="Created by" Binding="{Binding CreatedBy}" Width="95" />
                            <DataGridTextColumn Header="Modified" Binding="{Binding LastModified}" Width="140" />
                        </ds:AppDataGrid.Columns>
                    </ds:AppDataGrid>

                    <Border Grid.Column="2" Style="{StaticResource AppCardQuietStyle}" Padding="16"
                            Visibility="{Binding ShowDetailPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <!-- Square deposit breakdown -->
                                <StackPanel Visibility="{Binding ShowSquareDetail, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Visibility="{Binding ShowSquareAwaitingMatch, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Awaiting Square match" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12" />
                                        <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,12">
                                            This bank deposit is from Square but hasn't been matched to a Square payout yet.
                                            Import your Square transactions CSV to see what payments made up this deposit.
                                        </TextBlock>
                                        <ui:Button Content="Import Square CSV"
                                                   Style="{StaticResource PrimaryButtonStyle}"
                                                   Icon="{ui:SymbolIcon Payment24}"
                                                   Command="{Binding ImportSquareStatementCommand}"
                                                   HorizontalAlignment="Stretch" Margin="0,0,0,16" />
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding ShowSquareAwaitingMatch, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <TextBlock Text="Square Deposit" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12" />

                                    <TextBlock Text="Deposit Date" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="{Binding SquareDepositDate}" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,10" />

                                    <TextBlock Text="Gross Sales" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="{Binding SquareGrossSales, Converter={StaticResource CurrencyConverter}}"
                                               Style="{StaticResource BodyTextStyle}" Margin="0,0,0,10" />

                                    <TextBlock Text="Square Fees" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="{Binding SquareFees, Converter={StaticResource CurrencyConverter}}"
                                               Style="{StaticResource BodyTextStyle}" Margin="0,0,0,10" />

                                    <TextBlock Text="Net Deposit" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="{Binding SquareNetDeposit, Converter={StaticResource CurrencyConverter}}"
                                               Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,16" />

                                    <TextBlock Text="Transactions Included" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,8" />

                                    <ItemsControl ItemsSource="{Binding SquareDepositGroups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:SquareDepositGroupViewModel}">
                                                <Border Margin="0,0,0,8" Padding="0,0,0,4"
                                                        BorderBrush="{DynamicResource BrandBorderBrush}"
                                                        BorderThickness="0,0,0,1">
                                                    <StackPanel>
                                                        <ui:Button Style="{StaticResource ToolbarButtonStyle}"
                                                                HorizontalContentAlignment="Stretch"
                                                                Padding="0,4"
                                                                Command="{Binding DataContext.ToggleSquareGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Margin="0,0,6,0" FontSize="11"
                                                                           Foreground="{DynamicResource BrandMutedTextBrush}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="▶" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                    <Setter Property="Text" Value="▼" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Grid.Column="1" Text="{Binding DisplayTitle}"
                                                                           Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" />
                                                                <TextBlock Grid.Column="2" Text="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}}"
                                                                           Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" />
                                                            </Grid>
                                                        </ui:Button>

                                                        <ItemsControl ItemsSource="{Binding Items}"
                                                                      Margin="18,4,0,0"
                                                                      Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Margin="0,0,0,10">
                                                                        <TextBlock Text="{Binding Description}" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" />
                                                                        <TextBlock Text="{Binding CustomerName, StringFormat=• {0}}"
                                                                                   Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,0" />
                                                                        <TextBlock Text="{Binding Amount, Converter={StaticResource CurrencyConverter}}"
                                                                                   Style="{StaticResource BodyTextStyle}" Margin="0,2,0,0" />
                                                                        <TextBlock Text="{Binding TransactionTime, StringFormat=dd/MM/yyyy h:mm tt}"
                                                                                   Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,0" />
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Receipt details -->
                                <StackPanel Visibility="{Binding ShowSquareDetail, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <TextBlock Text="Transaction details" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12" />
                                    <Border Height="120" CornerRadius="8" Background="#1e293b" Margin="0,0,0,12">
                                        <Image Source="{Binding DetailThumbnail}" Stretch="Uniform" MaxHeight="120" />
                                    </Border>
                                    <TextBlock Text="Receipt status" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="{Binding DetailReceiptStatus}" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8" />
                                    <TextBlock Text="Category" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="{Binding SelectedTransaction.CategoryName, Mode=OneWay}" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8" />
                                    <TextBlock Text="Notes" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="{Binding SelectedTransaction.Notes, Mode=OneWay}" Style="{StaticResource CaptionTextStyle}"
                                               TextWrapping="Wrap" Margin="0,0,0,8" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,12">
                                        <Run Text="{Binding DetailAttachmentCount, Mode=OneWay}" />
                                        <Run Text=" attachment(s)" />
                                    </TextBlock>
                                    <UniformGrid Columns="2" Rows="2">
                                        <ui:Button Content="View receipt" Style="{StaticResource PrimaryButtonStyle}"
                                                   Command="{Binding ViewReceiptsCommand}"
                                                   HorizontalAlignment="Stretch" MinHeight="36" Margin="0,0,4,4" />
                                        <ui:Button Content="Replace" Style="{StaticResource SecondaryButtonStyle}"
                                                   Command="{Binding ReplaceReceiptCommand}"
                                                   HorizontalAlignment="Stretch" MinHeight="36" Margin="4,0,0,4" />
                                        <ui:Button Content="Add another" Style="{StaticResource SecondaryButtonStyle}"
                                                   Command="{Binding AddAnotherReceiptCommand}"
                                                   HorizontalAlignment="Stretch" MinHeight="36" Margin="0,4,4,0" />
                                        <ui:Button Content="Remove" Style="{StaticResource SecondaryButtonStyle}"
                                                   Command="{Binding RemoveReceiptCommand}"
                                                   HorizontalAlignment="Stretch" MinHeight="36" Margin="4,4,0,0" />
                                    </UniformGrid>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <ds:EmptyState Grid.Column="0" Grid.ColumnSpan="3" Title="{Binding EmptyTitle}"
                                   Message="{Binding EmptyMessage}"
                                   IconSymbol="List24"
                                   Visibility="{Binding Transactions, Converter={StaticResource EmptyCollectionToVisibilityConverter}}" />
                </Grid>
            </ds:SurfaceCard>
        </Grid>
    </ds:PageShell>
</UserControl>
