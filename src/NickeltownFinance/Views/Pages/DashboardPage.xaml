<UserControl x:Class="NickeltownFinance.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ds="clr-namespace:NickeltownFinance.Controls"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Style="{StaticResource PageRootStyle}">
    <ds:PageShell IsBusy="{Binding IsBusy}" ErrorMessage="{Binding ErrorMessage}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,4,0">
            <Grid Margin="0,0,8,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Dashboard" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Style="{StaticResource PageSubtitleStyle}">
                            <Run Text="{Binding ClubName, Mode=OneWay}" />
                            <Run Text="  ·  " />
                            <Run Text="{Binding FinancialYearName, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <ui:Button Grid.Column="1"
                               Icon="{ui:SymbolIcon ArrowSync24}"
                               Style="{StaticResource ToolbarButtonStyle}"
                               ToolTip="Refresh"
                               Command="{Binding RefreshCommand}"
                               VerticalAlignment="Top" />
                </Grid>

                <!-- Summary cards -->
                <Grid Grid.Row="1" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ds:MoneyCard Grid.Column="0"
                                  Title="Current bank balance"
                                  Amount="{Binding BankBalance}"
                                  Tone="Neutral" />
                    <ds:MoneyCard Grid.Column="2"
                                  Title="Income this month"
                                  Amount="{Binding IncomeThisMonth}"
                                  Tone="Income" />
                    <ds:MoneyCard Grid.Column="4"
                                  Title="Expenses this month"
                                  Amount="{Binding ExpensesThisMonth}"
                                  Tone="Expense" />
                    <ds:MoneyCard Grid.Column="6"
                                  Title="Current profit / loss"
                                  Amount="{Binding CurrentProfitLoss}"
                                  Tone="Profit" />
                </Grid>

                <!-- Import status -->
                <Border Grid.Row="2" Style="{StaticResource AppCardStyle}" Padding="20" Margin="0,0,0,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Import status" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                            <ui:Button Content="Import ANZ Statement" Style="{StaticResource SecondaryButtonStyle}"
                                       HorizontalAlignment="Right"
                                       Command="{Binding GoImportCommand}" />
                        </Grid>
                        <UniformGrid Grid.Row="1" Columns="3">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Last import date" Style="{StaticResource DetailLabelStyle}" />
                                <TextBlock Text="{Binding LastBankImportText}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Transactions waiting review" Style="{StaticResource DetailLabelStyle}" />
                                <TextBlock Text="{Binding TransactionsWaitingReview}" FontSize="22" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandWarningBrush}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Current financial year" Style="{StaticResource DetailLabelStyle}" />
                                <TextBlock Text="{Binding FinancialYearName}" FontSize="16" FontWeight="SemiBold" />
                            </StackPanel>
                        </UniformGrid>
                    </Grid>
                </Border>

                <!-- Mid band: chart + receipts + actions -->
                <Grid Grid.Row="3" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" MinWidth="260" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" MinWidth="200" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource AppCardStyle}" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="220" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Monthly cash flow"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,8" />
                            <lvc:CartesianChart Grid.Row="1"
                                                Background="Transparent"
                                                Series="{Binding CashFlowSeries}"
                                                XAxes="{Binding CashFlowXAxes}"
                                                YAxes="{Binding CashFlowYAxes}"
                                                LegendPosition="Top"
                                                LegendTextPaint="{Binding LegendTextPaint}"
                                                TooltipPosition="Top"
                                                TooltipBackgroundPaint="{Binding TooltipBackgroundPaint}"
                                                TooltipTextPaint="{Binding TooltipTextPaint}"
                                                AnimationsSpeed="0:0:0.18" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <Border Style="{StaticResource AppCardStyle}" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Financial year"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="{Binding FinancialYearName}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandTextPrimaryBrush}" />
                                <TextBlock Text="{Binding YearEndSummary}"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource AppCardStyle}" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Quick actions"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,12" />
                                <ui:Button Content="Import ANZ Statement"
                                           Icon="{ui:SymbolIcon ArrowUpload24}"
                                           Style="{StaticResource PrimaryButtonStyle}"
                                           HorizontalAlignment="Stretch"
                                           Margin="0,0,0,8"
                                           Command="{Binding GoImportCommand}" />
                                <ui:Button Content="Add Transaction"
                                           Icon="{ui:SymbolIcon Add24}"
                                           Style="{StaticResource SuccessButtonStyle}"
                                           HorizontalAlignment="Stretch"
                                           Margin="0,0,0,8"
                                           Command="{Binding AddTransactionCommand}" />
                                <ui:Button Content="Generate Monthly Report"
                                           Icon="{ui:SymbolIcon DataBarVertical24}"
                                           Style="{StaticResource ToolbarButtonStyle}"
                                           HorizontalAlignment="Stretch"
                                           Margin="0,0,0,8"
                                           Command="{Binding GoReportsCommand}" />
                                <ui:Button Content="Generate AGM Report"
                                           Icon="{ui:SymbolIcon DocumentOnePage24}"
                                           Style="{StaticResource ToolbarButtonStyle}"
                                           HorizontalAlignment="Stretch"
                                           Command="{Binding GoAgmReportCommand}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Bottom: transactions + activity -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" MinWidth="260" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" MinWidth="180" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource AppCardStyle}" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Recent transactions"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0"
                                           VerticalAlignment="Center" />
                                <ui:Button Grid.Column="1"
                                           Content="View all"
                                           Style="{StaticResource GhostButtonStyle}"
                                           Command="{Binding GoTransactionsCommand}" />
                            </Grid>

                            <StackPanel Grid.Row="1">
                                <TextBlock Text="No transactions yet"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Margin="0,16,0,8"
                                           Visibility="{Binding RecentTransactions, Converter={StaticResource EmptyCollectionToVisibilityConverter}}" />

                                <ItemsControl ItemsSource="{Binding RecentTransactions}"
                                              Visibility="{Binding RecentTransactions, Converter={StaticResource EmptyCollectionToVisibilityConverter}, ConverterParameter=Invert}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource TransactionRowStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="72" />
                                                        <ColumnDefinition Width="*" MinWidth="80" />
                                                        <ColumnDefinition Width="90" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding Date, StringFormat=dd/MM/yyyy}"
                                                               Style="{StaticResource CaptionTextStyle}"
                                                               VerticalAlignment="Center" />

                                                    <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontSize="14"
                                                                   FontWeight="Medium"
                                                                   Foreground="{StaticResource BrandTextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding CategoryName}"
                                                                   Style="{StaticResource CaptionTextStyle}"
                                                                   Margin="0,2,0,0"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding DisplayAmount, Converter={StaticResource CurrencyConverter}}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource BrandExpenseBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsIncome}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource BrandIncomeBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource AppCardStyle}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Recent activity"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="No recent activity"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,12,0,0"
                                       Visibility="{Binding RecentActivity, Converter={StaticResource EmptyCollectionToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding RecentActivity}"
                                          Visibility="{Binding RecentActivity, Converter={StaticResource EmptyCollectionToVisibilityConverter}, ConverterParameter=Invert}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,10"
                                                BorderBrush="{StaticResource BrandBorderSubtleBrush}"
                                                BorderThickness="0,0,0,1">
                                            <TextBlock Text="{Binding}"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </ds:PageShell>
</UserControl>
