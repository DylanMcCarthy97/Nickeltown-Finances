<UserControl x:Class="NickeltownFinance.Views.Pages.AgmReportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ds="clr-namespace:NickeltownFinance.Controls"
             Style="{StaticResource PageRootStyle}">
    <ds:PageShell IsBusy="{Binding IsBusy}" ErrorMessage="{Binding ErrorMessage}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="AGM report" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="Annual financial summary for the AGM."
                               Style="{StaticResource PageSubtitleStyle}" />
                </StackPanel>

                <ds:SurfaceCard CardMargin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MaxWidth="360" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Financial year" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox ItemsSource="{Binding FinancialYears}" SelectedItem="{Binding SelectedFinancialYear}" DisplayMemberPath="Name" />
                        </StackPanel>
                        <ui:Button Grid.Column="2" Content="Generate report"
                                   Style="{StaticResource PrimaryButtonStyle}"
                                   Icon="{ui:SymbolIcon DocumentOnePage24}"
                                   VerticalAlignment="Bottom"
                                   Command="{Binding GenerateReportCommand}" />
                    </Grid>
                </ds:SurfaceCard>

                <ds:SurfaceCard Title="Quick exports" CardMargin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Export summaries for the selected financial year without generating the full AGM report."
                                   Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" Margin="0,0,0,12" />
                        <WrapPanel>
                            <ui:Button Content="Category summary (Excel)" Style="{StaticResource GroupedSecondaryButtonExtraWideStyle}"
                                       Command="{Binding ExportCategorySummaryExcelCommand}" Margin="{StaticResource ButtonGroupMargin}" />
                            <ui:Button Content="GST summary (Excel)" Style="{StaticResource GroupedSecondaryButtonExtraWideStyle}"
                                       Command="{Binding ExportGstSummaryExcelCommand}" Margin="{StaticResource ButtonGroupMargin}" />
                            <ui:Button Content="Receipt audit (Excel)" Style="{StaticResource GroupedSecondaryButtonExtraWideStyle}"
                                       Command="{Binding ExportReceiptAuditExcelCommand}" Margin="{StaticResource ButtonGroupMargin}" />
                        </WrapPanel>
                    </StackPanel>
                </ds:SurfaceCard>

                <StackPanel Visibility="{Binding HasReport, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ds:SurfaceCard CardMargin="0,0,0,14" CardPadding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="Print" Icon="{ui:SymbolIcon Print24}" Style="{StaticResource GroupedSecondaryButtonStyle}" Margin="{StaticResource ButtonGroupMarginInline}" Command="{Binding PrintCommand}" />
                            <ui:Button Content="Export PDF" Icon="{ui:SymbolIcon DocumentPdf24}" Style="{StaticResource GroupedSecondaryButtonStyle}" Margin="{StaticResource ButtonGroupMarginInline}" Command="{Binding ExportPdfCommand}" />
                            <ui:Button Content="Export Excel" Icon="{ui:SymbolIcon Table24}" Style="{StaticResource GroupedSecondaryButtonStyle}" Command="{Binding ExportExcelCommand}" />
                        </StackPanel>
                    </ds:SurfaceCard>

                    <ds:ReportCard ClubName="{Binding ReportData.ClubName}"
                                   ReportTitle="Annual General Meeting Report"
                                   Subtitle="{Binding ReportData.FinancialYearName, StringFormat=Financial year {0}}">
                        <StackPanel DataContext="{Binding ReportData}">
                            <TextBlock Margin="0,0,0,16" TextWrapping="Wrap"
                                       Style="{StaticResource CaptionTextStyle}">
                                <Run Text="Signed by " />
                                <Run Text="{Binding PreparedBy, Mode=OneWay}" FontWeight="SemiBold" />
                                <Run Text=" (" />
                                <Run Text="{Binding PreparedByRole, Mode=OneWay}" />
                                <Run Text=")  ·  " />
                                <Run Text="{Binding PrintedAtDisplay, Mode=OneWay}" />
                            </TextBlock>

                            <UniformGrid Columns="4" Margin="0,0,0,18">
                                <ds:MoneyCard Title="Opening" Amount="{Binding OpeningBalance}" Tone="Neutral" ShowIcon="False" />
                                <ds:MoneyCard Title="Total income" Amount="{Binding TotalIncome}" Tone="Income" ShowIcon="False" />
                                <ds:MoneyCard Title="Total expenses" Amount="{Binding TotalExpenses}" Tone="Expense" ShowIcon="False" />
                                <ds:MoneyCard Title="Annual profit" Amount="{Binding AnnualProfit}" Tone="Profit" ShowIcon="False" />
                            </UniformGrid>

                            <ds:ReportSectionHeader Title="Monthly summary" />
                            <ds:AppDataGrid ItemsSource="{Binding MonthlyData}"
                                            Margin="0,0,0,18">
                                <ds:AppDataGrid.Columns>
                                    <DataGridTextColumn Header="Month" Binding="{Binding MonthName}" Width="2*" MinWidth="90" />
                                    <DataGridTextColumn Header="Income" Binding="{Binding Income, Converter={StaticResource CurrencyConverter}}" Width="*" MinWidth="80" />
                                    <DataGridTextColumn Header="Expenses" Binding="{Binding Expenses, Converter={StaticResource CurrencyConverter}}" Width="*" MinWidth="80" />
                                    <DataGridTextColumn Header="Profit" Binding="{Binding Profit, Converter={StaticResource CurrencyConverter}}" Width="*" MinWidth="80" />
                                </ds:AppDataGrid.Columns>
                            </ds:AppDataGrid>

                            <ds:ReportLine Label="Closing balance" Amount="{Binding ClosingBalance}" IsBold="True" LineMargin="0,0,0,8" />

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ds:StatisticCard Title="Income by category">
                                    <ItemsControl ItemsSource="{Binding IncomeByCategory}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ds:ReportLine Label="{Binding CategoryName}" Amount="{Binding Amount}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ds:StatisticCard>

                                <ds:StatisticCard Grid.Column="2" Title="Expenses by category">
                                    <ItemsControl ItemsSource="{Binding ExpensesByCategory}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ds:ReportLine Label="{Binding CategoryName}" Amount="{Binding Amount}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ds:StatisticCard>
                            </Grid>

                            <Border Style="{StaticResource AppCardStyle}" Padding="20" Margin="0,20,0,0">
                                <StackPanel>
                                    <TextBlock Text="Treasurer declaration" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,6" />
                                    <TextBlock Text="I confirm this report is a true and fair summary of the club's finances for the financial year."
                                               Style="{StaticResource CaptionTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,16" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" MinHeight="56" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="Full name" Style="{StaticResource DetailLabelStyle}" />
                                        <TextBlock Grid.Row="0" Grid.Column="2"
                                                   Text="Signature" Style="{StaticResource DetailLabelStyle}" />
                                        <TextBlock Grid.Row="0" Grid.Column="4"
                                                   Text="Date" Style="{StaticResource DetailLabelStyle}" />

                                        <StackPanel Grid.Row="1" Grid.Column="0"
                                                    Margin="0,8,0,8"
                                                    VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding PreparedBy}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding PreparedByRole}"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="2"
                                                    Margin="0,8,0,8"
                                                    VerticalAlignment="Bottom">
                                            <Image Source="{Binding SignatureImagePath, Converter={StaticResource PathToImageSourceConverter}}"
                                                   MaxHeight="48"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Left"
                                                   Visibility="{Binding HasSignature, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <TextBlock Text="Digitally signed"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Margin="0,4,0,0"
                                                       Visibility="{Binding HasSignature, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <TextBlock Text="Draw your signature in Settings → Report settings"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding HasSignature, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                        </StackPanel>

                                        <TextBlock Grid.Row="1" Grid.Column="4"
                                                   Text="{Binding PrintedAt, StringFormat=dd/MM/yyyy}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,8,0,8"
                                                   VerticalAlignment="Bottom" />

                                        <Border Grid.Row="2" Grid.Column="0"
                                                BorderBrush="{StaticResource BrandBorderSubtleBrush}"
                                                BorderThickness="0,0,0,1" />
                                        <Border Grid.Row="2" Grid.Column="2"
                                                BorderBrush="{StaticResource BrandBorderSubtleBrush}"
                                                BorderThickness="0,0,0,1" />
                                        <Border Grid.Row="2" Grid.Column="4"
                                                BorderBrush="{StaticResource BrandBorderSubtleBrush}"
                                                BorderThickness="0,0,0,1" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ds:ReportCard>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </ds:PageShell>
</UserControl>
