<UserControl x:Class="NickeltownFinance.Views.Pages.UserManagementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ds="clr-namespace:NickeltownFinance.Controls"
             Style="{StaticResource PageRootStyle}">
    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewUserCommand}" />
    </UserControl.InputBindings>

    <ds:PageShell IsBusy="{Binding IsBusy}" ErrorMessage="{Binding ErrorMessage}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="User management"
                               Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="Manage accounts, roles, signatures, and account access."
                               Style="{StaticResource PageSubtitleStyle}" />
                </StackPanel>
                <ui:Button Grid.Column="1"
                           Content="New user"
                           Icon="{ui:SymbolIcon PersonAdd24}"
                           Style="{StaticResource PrimaryButtonStyle}"
                           Command="{Binding NewUserCommand}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
            </Grid>

            <Grid Grid.Row="1">
                <ds:SurfaceCard CardMargin="0" CardPadding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource AppCardQuietStyle}"
                                Padding="12"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ds:SearchBar Grid.Column="0"
                                              Placeholder="Search users..."
                                              Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                              ShowButton="False"
                                              TextBoxMargin="0"
                                              VerticalAlignment="Center" />

                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding RoleFilterOptions}"
                                          SelectedItem="{Binding RoleFilter}"
                                          VerticalAlignment="Center"
                                          MinHeight="36"
                                          ToolTip="Filter by role" />

                                <ui:Button Grid.Column="4"
                                           Content="Refresh"
                                           Icon="{ui:SymbolIcon ArrowSync24}"
                                           Style="{StaticResource GroupedToolbarButtonStyle}"
                                           Command="{Binding RefreshCommand}"
                                           ToolTip="Refresh list (F5)" />
                            </Grid>
                        </Border>

                        <ds:AppDataGrid Grid.Row="1"
                                        ItemsSource="{Binding Users}"
                                        SelectedItem="{Binding SelectedUser}"
                                        CanUserSortColumns="True"
                                        LayoutKey="Users"
                                        MinRowHeight="44"
                                        MouseDoubleClick="UsersGrid_OnMouseDoubleClick">
                            <ds:AppDataGrid.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="Open"
                                              Command="{Binding OpenUserCommand}"
                                              Icon="{ui:SymbolIcon Open24}" />
                                    <MenuItem Header="Unlock Account"
                                              Command="{Binding UnlockUserCommand}"
                                              Icon="{ui:SymbolIcon LockOpen24}"
                                              Visibility="{Binding DetailIsLocked, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </ContextMenu>
                            </ds:AppDataGrid.ContextMenu>
                            <ds:AppDataGrid.Columns>
                                <DataGridTemplateColumn Header="" Width="44" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid Width="28" Height="28" HorizontalAlignment="Center">
                                                <Ellipse Fill="{DynamicResource ControlFillColorDefaultBrush}" />
                                                <Ellipse>
                                                    <Ellipse.Fill>
                                                        <ImageBrush ImageSource="{Binding ProfilePicturePath, Converter={StaticResource PathToImageSourceConverter}}"
                                                                    Stretch="UniformToFill" />
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock Text="{Binding AvatarInitials}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding ProfilePicturePath, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}, ConverterParameter=Invert}" />
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Username"
                                                    Binding="{Binding Username}"
                                                    Width="1.1*"
                                                    MinWidth="90" />
                                <DataGridTextColumn Header="Full name"
                                                    Binding="{Binding DisplayName}"
                                                    Width="1.3*"
                                                    MinWidth="110" />
                                <DataGridTextColumn Header="Role"
                                                    Binding="{Binding RoleDisplay}"
                                                    Width="120" />
                                <DataGridTemplateColumn Header="Status" Width="96">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10"
                                                    Padding="8,2"
                                                    HorizontalAlignment="Left"
                                                    Background="{Binding StatusKind, Converter={StaticResource StatusBadgeBackgroundConverter}}">
                                                <TextBlock Text="{Binding StatusText}"
                                                           Foreground="White"
                                                           FontSize="11"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Last Login"
                                                    Binding="{Binding LastLoginDisplay}"
                                                    Width="140" />
                            </ds:AppDataGrid.Columns>
                        </ds:AppDataGrid>
                    </Grid>
                </ds:SurfaceCard>

                <!-- Popup editor -->
                <Border Panel.ZIndex="50"
                        Background="#6A000000"
                        Visibility="{Binding IsDetailsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ds:SurfaceCard Width="900" MaxWidth="900" CardMargin="0" CardPadding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="48" Height="48" Margin="0,0,12,0" Cursor="Hand" ToolTip="Change photo" MouseLeftButtonUp="Avatar_OnMouseLeftButtonUp">
                                        <Ellipse Fill="{DynamicResource ControlFillColorDefaultBrush}" />
                                        <Ellipse>
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding EditProfilePicturePath, Converter={StaticResource PathToImageSourceConverter}}" Stretch="UniformToFill" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="{Binding DetailAvatarInitials}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding EditProfilePicturePath, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}, ConverterParameter=Invert}" />
                                    </Grid>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding EditDisplayName}" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding DetailRoleDisplay}" Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <ui:Button Grid.Column="2" Content="Close" Style="{StaticResource GroupedSecondaryButtonStyle}" Click="CloseEditor_OnClick" />
                                </Grid>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Style="{StaticResource AppCardQuietStyle}" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Profile" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,10" />
                                                <TextBlock Text="Username" Style="{StaticResource DetailLabelStyle}" />
                                                <ui:TextBox Text="{Binding EditUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                                <TextBlock Text="Full name" Style="{StaticResource DetailLabelStyle}" />
                                                <ui:TextBox Text="{Binding EditDisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                                <TextBlock Text="Role" Style="{StaticResource DetailLabelStyle}" />
                                                <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding EditRole}" Margin="0,0,0,10">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource RoleDisplayConverter}}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <CheckBox Content="Account Active" IsChecked="{Binding EditIsActive}" />
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Grid.Column="2">
                                            <Border Style="{StaticResource AppCardQuietStyle}" Padding="14" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="Digital signature" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8" />
                                                    <Border Background="{StaticResource BrandInsetBrush}" CornerRadius="10" Padding="12" MinHeight="74" Margin="0,0,0,10">
                                                        <Grid>
                                                            <TextBlock Text="No signature uploaded" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding EditHasSignature, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                                            <Image Source="{Binding EditSignatureImagePath, Converter={StaticResource PathToImageSourceConverter}}" MaxHeight="64" Stretch="Uniform" HorizontalAlignment="Left" Visibility="{Binding EditHasSignature, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                        </Grid>
                                                    </Border>
                                                    <UniformGrid Columns="3">
                                                        <ui:Button Content="Draw signature" Style="{StaticResource GroupedSecondaryButtonStyle}" Icon="{ui:SymbolIcon DrawImage24}" Command="{Binding DrawSignatureCommand}" Margin="{StaticResource ButtonGroupMarginInline}" />
                                                        <ui:Button Content="Upload image" Style="{StaticResource GroupedSecondaryButtonStyle}" Command="{Binding BrowseSignatureCommand}" Margin="{StaticResource ButtonGroupMarginInline}" />
                                                        <ui:Button Content="Remove" Style="{StaticResource GroupedSecondaryButtonStyle}" Command="{Binding ClearSignatureCommand}" IsEnabled="{Binding EditHasSignature}" />
                                                    </UniformGrid>
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource AppCardQuietStyle}" Padding="14">
                                                <StackPanel>
                                                    <TextBlock Text="Security" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,10" />
                                                    <TextBlock Text="Last login" Style="{StaticResource CaptionTextStyle}" />
                                                    <TextBlock Text="{Binding DetailLastLogin}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                                    <TextBlock Text="Password changed" Style="{StaticResource CaptionTextStyle}" />
                                                    <TextBlock Text="{Binding DetailPasswordChanged}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                                    <TextBlock Text="Created date" Style="{StaticResource CaptionTextStyle}" />
                                                    <TextBlock Text="{Binding DetailCreated}" FontWeight="SemiBold" />
                                                    <ui:Button Content="Unlock account" Appearance="Caution" Command="{Binding UnlockUserCommand}" Margin="0,10,0,0" Visibility="{Binding DetailIsLocked, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>

                                <UniformGrid Grid.Row="2" Columns="4" Margin="0,14,0,0">
                                    <ui:Button Content="Save changes" Style="{StaticResource GroupedPrimaryButtonStyle}" Command="{Binding SaveChangesCommand}" Margin="{StaticResource ButtonGroupMarginInline}" />
                                    <ui:Button Content="Reset password" Style="{StaticResource GroupedSecondaryButtonStyle}" Command="{Binding ResetPasswordCommand}" Margin="{StaticResource ButtonGroupMarginInline}" />
                                    <ui:Button Content="{Binding ActivateDeactivateLabel}" Style="{StaticResource GroupedSecondaryButtonStyle}" Command="{Binding ToggleActiveCommand}" Margin="{StaticResource ButtonGroupMarginInline}" />
                                    <ui:Button Content="Delete user" Style="{StaticResource GroupedDangerButtonStyle}" Command="{Binding DeleteUserCommand}" />
                                </UniformGrid>
                            </Grid>
                        </ds:SurfaceCard>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ds:PageShell>
</UserControl>
