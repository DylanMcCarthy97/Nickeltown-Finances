<UserControl x:Class="NickeltownFinance.Views.Pages.ReceiptInboxPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ds="clr-namespace:NickeltownFinance.Controls"
             Style="{StaticResource PageRootStyle}"
             AllowDrop="True"
             Drop="OnDrop"
             DragOver="OnDragOver">
    <ds:PageShell IsBusy="{Binding IsBusy}" ErrorMessage="{Binding ErrorMessage}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Receipt Inbox" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="Review receipts from mobile, desktop, and folders. Match to ANZ transactions or create new expenses."
                               Style="{StaticResource PageSubtitleStyle}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <ui:Button Content="Mobile upload" Icon="{ui:SymbolIcon Phone24}"
                               Style="{StaticResource GroupedSecondaryButtonWideStyle}"
                               Command="{Binding OpenMobileUploadCommand}" Margin="{StaticResource ButtonGroupMarginInline}" />
                    <ui:Button Content="Browse files" Icon="{ui:SymbolIcon FolderOpen24}"
                               Style="{StaticResource GroupedSecondaryButtonWideStyle}"
                               Command="{Binding BrowseFilesCommand}" Margin="{StaticResource ButtonGroupMarginInline}" />
                    <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}"
                               Style="{StaticResource GroupedSecondaryButtonWideStyle}"
                               Command="{Binding RefreshCommand}" Margin="{StaticResource ButtonGroupMarginInline}" />
                    <ui:Button Content="Back to Imports" Style="{StaticResource GroupedSecondaryButtonWideStyle}"
                               Command="{Binding BackToImportsCommand}" />
                </StackPanel>
            </Grid>

            <WrapPanel Grid.Row="1" Margin="0,0,0,12">
                <ui:Button Content="All" Margin="{StaticResource ButtonGroupMargin}"
                           Command="{Binding SelectTabCommand}" CommandParameter="All">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource TabFilterButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="All">
                                    <Setter Property="Background" Value="{StaticResource BrandPrimaryBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Content="Processing" Margin="{StaticResource ButtonGroupMargin}"
                           Command="{Binding SelectTabCommand}" CommandParameter="Processing">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource TabFilterButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="Processing">
                                    <Setter Property="Background" Value="{StaticResource BrandPrimaryBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Content="Ready" Margin="{StaticResource ButtonGroupMargin}"
                           Command="{Binding SelectTabCommand}" CommandParameter="Ready">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource TabFilterButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="Ready">
                                    <Setter Property="Background" Value="{StaticResource BrandPrimaryBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Content="Matched" Margin="{StaticResource ButtonGroupMargin}"
                           Command="{Binding SelectTabCommand}" CommandParameter="Matched">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource TabFilterButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="Matched">
                                    <Setter Property="Background" Value="{StaticResource BrandPrimaryBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Content="Needs Review" Margin="{StaticResource ButtonGroupMargin}"
                           Command="{Binding SelectTabCommand}" CommandParameter="Needs Review">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource TabFilterButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="Needs Review">
                                    <Setter Property="Background" Value="{StaticResource BrandPrimaryBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Content="Ignored" Margin="{StaticResource ButtonGroupMargin}"
                           Command="{Binding SelectTabCommand}" CommandParameter="Ignored">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource TabFilterButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="Ignored">
                                    <Setter Property="Background" Value="{StaticResource BrandPrimaryBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </WrapPanel>

            <Border Grid.Row="2" Style="{StaticResource AppCardQuietStyle}" Padding="12" Margin="0,0,0,12"
                    Visibility="{Binding EmptyStateMessage, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}">
                <TextBlock Text="{Binding EmptyStateMessage}" Style="{StaticResource BodyTextStyle}" TextWrapping="Wrap" />
            </Border>

            <Grid Grid.Row="3" Margin="0,0,0,12">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EmptyStateMessage, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}" Value="Visible">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <ui:TextBox PlaceholderText="Search invoice, ABN, total, category, receipt text…"
                            Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*" MinWidth="280" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" MinWidth="260" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource AppCardStyle}" Padding="8">
                    <ds:AppDataGrid ItemsSource="{Binding Items}"
                                    SelectedItem="{Binding SelectedItem}"
                                    IsReadOnly="True">
                        <ds:AppDataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="72">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="64" Height="64" CornerRadius="8" Background="#334155" Margin="4,2">
                                            <Image Source="{Binding ThumbnailPath, Converter={StaticResource PathToImageSourceConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Date" Binding="{Binding DateDisplay}" Width="75" />
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalDisplay}" Width="75" />
                            <DataGridTextColumn Header="Category" Binding="{Binding CategoryDisplay}" Width="90" />
                            <DataGridTextColumn Header="Source" Binding="{Binding SourceDisplay}" Width="65" />
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusLabel}" Width="100" />
                            <DataGridTextColumn Header="Uploaded" Binding="{Binding UploadedTimeDisplay}" Width="115" />
                        </ds:AppDataGrid.Columns>
                    </ds:AppDataGrid>
                </Border>

                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource AppCardStyle}" Padding="16" Margin="0,0,0,12"
                                Visibility="{Binding SelectedMatch.IsExcellentHighlight, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="✓ Excellent Match" Foreground="#22c55e" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SelectedMatch.QualityDisplay}" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap">
                                        <Run Text="{Binding SelectedMatch.Description, Mode=OneWay}" FontWeight="SemiBold" />
                                        <Run Text=" · " />
                                        <Run Text="{Binding SelectedMatch.Amount, StringFormat=C, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <ui:Button Content="Attach receipt" Style="{StaticResource PrimaryButtonStyle}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Command="{Binding MatchToTransactionCommand}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource AppCardStyle}" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Preview" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12" />
                                <Border MinHeight="220" Background="#1e293b" CornerRadius="8" Margin="0,0,0,12"
                                        Cursor="Hand" ToolTip="Double-click to open receipt viewer"
                                        MouseLeftButtonDown="Preview_OnMouseDoubleClick">
                                    <Grid>
                                        <Image Source="{Binding PreviewImage}" Stretch="Uniform" MaxHeight="320" />
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Visibility="{Binding ShowPdfPreview, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ui:SymbolIcon Symbol="DocumentPdf24" FontSize="48"
                                                           Foreground="{StaticResource BrandPrimaryBrush}"
                                                           HorizontalAlignment="Center" />
                                            <TextBlock Text="PDF receipt" Style="{StaticResource CaptionTextStyle}"
                                                       HorizontalAlignment="Center" Margin="0,8,0,0" />
                                        </StackPanel>
                                        <TextBlock Text="Select a receipt to preview"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <TextBlock Text="Processing status" Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Text="{Binding PreviewStatusText}" Style="{StaticResource BodyTextStyle}"
                                           TextWrapping="Wrap" Margin="0,0,0,8" />

                                <Border Style="{StaticResource AppCardQuietStyle}" Padding="10" Margin="0,0,0,12"
                                        Visibility="{Binding DuplicateWarning, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="{Binding DuplicateWarning}" Foreground="#fbbf24" TextWrapping="Wrap" />
                                </Border>

                                <TextBlock Text="Timeline" Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Text="{Binding TimelineDisplay}" Style="{StaticResource CaptionTextStyle}"
                                           TextWrapping="Wrap" Margin="0,0,0,12" />

                                <TextBlock Text="OCR extraction (editable)" Style="{StaticResource FieldLabelStyle}" />
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Supplier" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SupplierConfidence, Converter={StaticResource ConfidenceDisplayConverter}}"
                                               Foreground="{Binding SupplierConfidence, Converter={StaticResource ConfidenceToBrushConverter}}" Margin="8,0,0,4" />

                                    <ui:TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding EditSupplier, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Date" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DateConfidence, Converter={StaticResource ConfidenceDisplayConverter}}"
                                               Foreground="{Binding DateConfidence, Converter={StaticResource ConfidenceToBrushConverter}}" Margin="8,0,0,4" />
                                    <DatePicker Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" SelectedDate="{Binding EditDate}" Margin="0,0,0,8"
                                                CalendarStyle="{StaticResource AppCalendarStyle}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Total / GST / Subtotal" Style="{StaticResource CaptionTextStyle}" />
                                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding TotalConfidence, Converter={StaticResource ConfidenceDisplayConverter}}"
                                                   Foreground="{Binding TotalConfidence, Converter={StaticResource ConfidenceToBrushConverter}}" Margin="0,0,8,4" />
                                        <TextBlock Text="{Binding GstConfidence, Converter={StaticResource ConfidenceDisplayConverter}}"
                                                   Foreground="{Binding GstConfidence, Converter={StaticResource ConfidenceToBrushConverter}}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
                                        <ui:TextBox Width="90" PlaceholderText="Total" Text="{Binding EditTotal, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                                        <ui:TextBox Width="90" PlaceholderText="GST" Text="{Binding EditGst, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                                        <ui:TextBox Width="90" PlaceholderText="Subtotal" Text="{Binding EditSubtotal, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Invoice / ABN" Style="{StaticResource CaptionTextStyle}" />
                                    <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding InvoiceConfidence, Converter={StaticResource ConfidenceDisplayConverter}}"
                                                   Foreground="{Binding InvoiceConfidence, Converter={StaticResource ConfidenceToBrushConverter}}" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding AbnConfidence, Converter={StaticResource ConfidenceDisplayConverter}}"
                                                   Foreground="{Binding AbnConfidence, Converter={StaticResource ConfidenceToBrushConverter}}" />
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
                                    <ui:TextBox Width="140" PlaceholderText="Invoice #" Text="{Binding EditInvoiceNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                                    <ui:TextBox Width="140" PlaceholderText="ABN" Text="{Binding EditAbn, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                                    <ui:Button Content="Save OCR" Command="{Binding SaveOcrEditsCommand}" Style="{StaticResource GroupedSecondaryButtonStyle}" VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="AI category" Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Margin="0,0,0,12" TextWrapping="Wrap">
                                    <Run Text="{Binding SelectedItem.CategoryDisplay, Mode=OneWay}" />
                                    <Run Text="{Binding SelectedItem.ConfidenceDisplay, Mode=OneWay, StringFormat=' ({0})'}" />
                                </TextBlock>

                                <TextBlock Text="File details" Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Text="{Binding SelectedItem.FileName, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource AppCardStyle}" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Possible ANZ matches" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8" />
                                <TextBlock Text="No bank match found." Margin="0,0,0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MatchCandidates.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding MatchCandidates}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource AppCardQuietStyle}" Padding="10" Margin="0,0,0,8"
                                                    Background="{Binding Confidence, Converter={StaticResource MatchQualityBrushConverter}}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Description}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                        <TextBlock Style="{StaticResource CaptionTextStyle}">
                                                            <Run Text="{Binding Date, StringFormat=dd/MM/yyyy}" />
                                                            <Run Text=" · " />
                                                            <Run Text="{Binding Amount, StringFormat=C}" />
                                                            <Run Text=" · " />
                                                            <Run Text="{Binding QualityDisplay}" />
                                                            <Run Text=" · " />
                                                            <Run Text="{Binding Confidence, StringFormat={}{0}%}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <ui:Button Grid.Column="1" Content="Match"
                                                               Style="{StaticResource PrimaryButtonStyle}"
                                                               VerticalAlignment="Center"
                                                               Command="{Binding DataContext.MatchCandidateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               CommandParameter="{Binding}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <WrapPanel>
                            <ui:Button Content="Match to ANZ" Style="{StaticResource GroupedPrimaryButtonStyle}"
                                       Command="{Binding MatchToTransactionCommand}" Margin="{StaticResource ButtonGroupMargin}" />
                            <ui:Button Content="Create expense" Style="{StaticResource GroupedSecondaryButtonStyle}"
                                       Command="{Binding CreateNewExpenseCommand}" Margin="{StaticResource ButtonGroupMargin}" />
                            <ui:Button Content="Ignore" Style="{StaticResource GroupedSecondaryButtonStyle}"
                                       Command="{Binding IgnoreCommand}" Margin="{StaticResource ButtonGroupMargin}" />
                            <ui:Button Content="Reprocess" Style="{StaticResource GroupedSecondaryButtonStyle}"
                                       Command="{Binding ReprocessCommand}" Margin="{StaticResource ButtonGroupMargin}" />
                            <ui:Button Content="Open file" Style="{StaticResource GroupedSecondaryButtonStyle}"
                                       Command="{Binding OpenOriginalFileCommand}" Margin="{StaticResource ButtonGroupMargin}" />
                            <ui:Button Content="Delete" Style="{StaticResource GroupedDangerButtonStyle}"
                                       Command="{Binding DeleteCommand}" Margin="{StaticResource ButtonGroupMargin}" />
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </ds:PageShell>
</UserControl>
