<ui:FluentWindow x:Class="NickeltownFinance.Views.LoginWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:ds="clr-namespace:NickeltownFinance.Controls"
                 Title="Nickeltown Finance"
                 MinWidth="640" MinHeight="520"
                 Width="920" Height="680"
                 WindowStartupLocation="CenterScreen"
                 ResizeMode="CanResizeWithGrip"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Background="{DynamicResource BrandBackgroundBrush}"
                 Icon="pack://application:,,,/Assets/AppIcon.png"
                 FontFamily="{StaticResource AppFontFamily}">
    <Grid Background="{DynamicResource BrandBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title=""
                     Grid.Row="0"
                     ShowMaximize="True"
                     Background="{DynamicResource BrandBackgroundBrush}" />

        <!-- Centred sign-in -->
        <Grid Grid.Row="1">
            <Border Style="{StaticResource ElevatedCardStyle}"
                    MaxWidth="420"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="32"
                    Padding="36,32">
            <StackPanel Width="340">

                <Image Source="{StaticResource DefaultClubLogoImage}"
                       Width="80" Height="80"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Margin="0,0,0,20" />

                <TextBlock Text="Nickeltown Finance"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource BrandTextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />

                <TextBlock Text="Club treasurer tools for Nickeltown Flounderers Auto Club"
                           Style="{StaticResource CaptionTextStyle}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,8,0,4" />

                <TextBlock Text="Sign in to continue"
                           Style="{StaticResource CaptionTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,28" />

                <TextBlock Text="Username" Style="{StaticResource FieldLabelStyle}" />
                <ui:TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Username"
                            MinHeight="40"
                            Margin="0,0,0,16" />

                <TextBlock Text="Password" Style="{StaticResource FieldLabelStyle}" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <PasswordBox x:Name="PasswordBox"
                                 MinHeight="40"
                                 Margin="0,0,8,0"
                                 PasswordChanged="PasswordBox_OnPasswordChanged"
                                 KeyDown="PasswordBox_OnKeyDown"
                                 Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                    <ui:TextBox x:Name="VisiblePasswordBox"
                                Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                MinHeight="40"
                                Margin="0,0,8,0"
                                Visibility="{Binding IsPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                KeyDown="PasswordBox_OnKeyDown" />

                    <ui:Button Grid.Column="1"
                               MinWidth="44" MinHeight="40"
                               Padding="0"
                               Style="{StaticResource SecondaryButtonStyle}"
                               ToolTip="{Binding IsPasswordVisible, Converter={StaticResource PasswordVisibilityLabelConverter}}"
                               Command="{Binding TogglePasswordVisibilityCommand}">
                        <ui:SymbolIcon Symbol="Eye24"
                                       FontSize="18"
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                    </ui:Button>
                </Grid>

                <CheckBox Content="Remember me"
                          IsChecked="{Binding RememberUsername}"
                          Foreground="{DynamicResource BrandTextSecondaryBrush}"
                          Margin="0,4,0,16" />

                <TextBlock Text="{Binding SuccessMessage}"
                           Foreground="{DynamicResource BrandIncomeBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="{Binding SuccessMessage, Converter={StaticResource NullToVisibilityConverter}}" />

                <ds:ErrorScreen Message="{Binding ErrorMessage}" IsCompact="True" />

                <ui:Button Content="Sign in"
                           Style="{StaticResource PrimaryButtonStyle}"
                           HorizontalAlignment="Stretch"
                           MinHeight="44"
                           Margin="0,8,0,0"
                           Command="{Binding LoginCommand}"
                           IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                <ui:Button Content="Forgot password?"
                           Style="{StaticResource GhostButtonStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"
                           Command="{Binding OpenForgotPasswordCommand}" />

                <TextBlock Text="{Binding AppVersion}"
                           Style="{StaticResource CaptionTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,24,0,0" />
            </StackPanel>
            </Border>

            <!-- Forgot password overlay -->
            <Border Background="{DynamicResource BrandOverlayBrush}"
                    Visibility="{Binding ShowForgotPassword, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Style="{StaticResource ElevatedCardStyle}"
                        MaxWidth="440"
                        MaxHeight="640"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="24"
                        Padding="28,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Reset password"
                                       Style="{StaticResource PageTitleStyle}"
                                       FontSize="20" />
                            <TextBlock Text="An administrator must confirm their identity, then choose a user and set a new password."
                                       Style="{StaticResource PageSubtitleStyle}"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock Text="1. Administrator"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="{DynamicResource BrandTextPrimaryBrush}"
                                           Margin="0,0,0,10" />

                                <TextBlock Text="Admin username" Style="{StaticResource FieldLabelStyle}" />
                                <ui:TextBox Text="{Binding AdminUsername, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="admin"
                                            MinHeight="40"
                                            Margin="0,0,0,12" />

                                <TextBlock Text="Admin password" Style="{StaticResource FieldLabelStyle}" />
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <PasswordBox x:Name="AdminPasswordBox"
                                                 MinHeight="40"
                                                 Margin="0,0,8,0"
                                                 PasswordChanged="AdminPasswordBox_OnPasswordChanged"
                                                 Visibility="{Binding IsAdminPasswordVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <ui:TextBox Text="{Binding AdminPassword, UpdateSourceTrigger=PropertyChanged}"
                                                MinHeight="40"
                                                Margin="0,0,8,0"
                                                Visibility="{Binding IsAdminPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <ui:Button Grid.Column="1"
                                               MinWidth="44" MinHeight="40"
                                               Padding="0"
                                               Style="{StaticResource SecondaryButtonStyle}"
                                               ToolTip="{Binding IsAdminPasswordVisible, Converter={StaticResource PasswordVisibilityLabelConverter}}"
                                               Command="{Binding ToggleAdminPasswordVisibilityCommand}">
                                        <ui:SymbolIcon Symbol="Eye24" FontSize="18"
                                                       Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                                    </ui:Button>
                                </Grid>

                                <TextBlock Text="2. Account to reset"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="{DynamicResource BrandTextPrimaryBrush}"
                                           Margin="0,0,0,10" />

                                <TextBlock Text="User" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding ResetUsers}"
                                          SelectedItem="{Binding SelectedResetUser}"
                                          DisplayMemberPath="Label"
                                          MinHeight="40"
                                          Margin="0,0,0,20" />

                                <TextBlock Text="3. New password"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="{DynamicResource BrandTextPrimaryBrush}"
                                           Margin="0,0,0,10" />

                                <TextBlock Text="New password" Style="{StaticResource FieldLabelStyle}" />
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <PasswordBox x:Name="ResetNewPasswordBox"
                                                 MinHeight="40"
                                                 Margin="0,0,8,0"
                                                 PasswordChanged="ResetNewPasswordBox_OnPasswordChanged"
                                                 Visibility="{Binding IsResetPasswordVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <ui:TextBox Text="{Binding ResetNewPassword, UpdateSourceTrigger=PropertyChanged}"
                                                MinHeight="40"
                                                Margin="0,0,8,0"
                                                Visibility="{Binding IsResetPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <ui:Button Grid.Column="1"
                                               MinWidth="44" MinHeight="40"
                                               Padding="0"
                                               Style="{StaticResource SecondaryButtonStyle}"
                                               ToolTip="{Binding IsResetPasswordVisible, Converter={StaticResource PasswordVisibilityLabelConverter}}"
                                               Command="{Binding ToggleResetPasswordVisibilityCommand}">
                                        <ui:SymbolIcon Symbol="Eye24" FontSize="18"
                                                       Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                                    </ui:Button>
                                </Grid>

                                <ProgressBar Minimum="0" Maximum="4"
                                             Value="{Binding ResetPasswordStrength}"
                                             Height="6"
                                             Margin="0,0,0,2"
                                             Foreground="{Binding ResetPasswordStrength, Converter={StaticResource PasswordStrengthBrushConverter}}" />
                                <TextBlock Text="{Binding ResetPasswordStrengthLabel}"
                                           Opacity="0.7"
                                           FontSize="11"
                                           Margin="0,0,0,12" />

                                <TextBlock Text="Confirm password" Style="{StaticResource FieldLabelStyle}" />
                                <PasswordBox x:Name="ResetConfirmPasswordBox"
                                             MinHeight="40"
                                             Margin="0,0,0,8"
                                             PasswordChanged="ResetConfirmPasswordBox_OnPasswordChanged"
                                             Visibility="{Binding IsResetPasswordVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                <ui:TextBox Text="{Binding ResetConfirmPassword, UpdateSourceTrigger=PropertyChanged}"
                                            MinHeight="40"
                                            Margin="0,0,0,8"
                                            Visibility="{Binding IsResetPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <TextBlock Text="Use 8+ characters with uppercase, lowercase, a number, and a special character."
                                           Opacity="0.55"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />

                                <ds:ErrorScreen Message="{Binding ResetMessage}" IsCompact="True" />
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,16,0,0">
                            <ui:Button Content="Cancel"
                                       Style="{StaticResource SecondaryButtonStyle}"
                                       Margin="0,0,8,0"
                                       MinWidth="100"
                                       Command="{Binding CloseForgotPasswordCommand}"
                                       IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                            <ui:Button Content="Reset password"
                                       Style="{StaticResource PrimaryButtonStyle}"
                                       MinWidth="140"
                                       Command="{Binding ResetPasswordCommand}"
                                       IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
