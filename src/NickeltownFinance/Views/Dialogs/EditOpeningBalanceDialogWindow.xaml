<ui:FluentWindow x:Class="NickeltownFinance.Views.Dialogs.EditOpeningBalanceDialogWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:ds="clr-namespace:NickeltownFinance.Controls"
                 Title="Edit Starting Balance"
                 Width="460"
                 SizeToContent="Height"
                 MinHeight="380"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Background="{StaticResource BrandBackgroundBrush}"
                 FontFamily="{StaticResource AppFontFamily}">
    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
        <KeyBinding Key="Enter" Command="{Binding SaveCommand}" />
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Edit Starting Balance" Grid.Row="0" ShowMinimize="False" ShowMaximize="False" />

        <StackPanel Grid.Row="1" Margin="28,8,28,8">
            <TextBlock Text="Financial year" Style="{StaticResource FieldLabelStyle}" />
            <ui:TextBox Text="{Binding FinancialYearName}" IsReadOnly="True" Margin="0,0,0,12" />

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Starting date" Style="{StaticResource FieldLabelStyle}" />
                    <ds:AppDateField SelectedDate="{Binding OpeningDate}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Current bank balance" Style="{StaticResource FieldLabelStyle}" />
                    <ui:TextBox Text="{Binding OpeningBalanceText, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="0.00" />
                </StackPanel>
            </Grid>

            <TextBlock Text="Notes" Style="{StaticResource FieldLabelStyle}" />
            <ui:TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                        AcceptsReturn="True"
                        Height="72"
                        Margin="0,0,0,8" />

            <TextBlock Text="Enter the bank balance at the end of your starting date. Transactions on or before that day are already included and will not change the current balance."
                       FontSize="11"
                       Foreground="{StaticResource BrandMutedTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />

            <ds:ErrorScreen Message="{Binding ErrorMessage}" IsCompact="True" />
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource DialogFooterStyle}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancel" Style="{StaticResource DialogFooterButtonStyle}"
                           Command="{Binding CancelCommand}" Margin="{StaticResource ButtonGroupMarginInline}" />
                <ui:Button Content="Save" Style="{StaticResource DialogFooterPrimaryButtonStyle}"
                           Command="{Binding SaveCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
