<ui:FluentWindow x:Class="NickeltownFinance.Views.Dialogs.ReceiptViewerWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{Binding Title}"
                 Width="1100" Height="780"
                 MinWidth="820" MinHeight="560"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="None"
                 Background="{StaticResource BrandBackgroundBrush}"
                 FontFamily="{StaticResource AppFontFamily}"
                 Icon="pack://application:,,,/Assets/AppIcon.png"
                 PreviewMouseWheel="Window_PreviewMouseWheel"
                 PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
                 PreviewMouseMove="Window_PreviewMouseMove"
                 PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ui:TitleBar Title="{Binding Title}" Grid.Row="0" />

        <Border Grid.Row="1" Style="{StaticResource ToolbarPanelStyle}" Margin="16,8,16,8">
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding ShowViewModeTabs, Converter={StaticResource BoolToVisibilityConverter}}">
                <ui:Button Content="Enhanced" Margin="0,0,6,0"
                           Command="{Binding SetViewModeCommand}" CommandParameter="Enhanced" />
                <ui:Button Content="Original" Margin="0,0,6,0"
                           Command="{Binding SetViewModeCommand}" CommandParameter="Original" />
                <ui:Button Content="OCR Debug" Margin="0,0,6,0"
                           Visibility="{Binding ShowOcrDebugTab, Converter={StaticResource BoolToVisibilityConverter}}"
                           Command="{Binding SetViewModeCommand}" CommandParameter="OcrDebug" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ToolbarPanelStyle}" Margin="16,0,16,12">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <ui:Button Icon="{ui:SymbolIcon ChevronLeft24}" ToolTip="Previous document" Command="{Binding PreviousAttachmentCommand}" Style="{StaticResource GroupedToolbarButtonStyle}" Margin="0,0,6,0" />
                    <ui:Button Icon="{ui:SymbolIcon ChevronRight24}" ToolTip="Next document" Command="{Binding NextAttachmentCommand}" Style="{StaticResource GroupedToolbarButtonStyle}" Margin="0,0,12,0" />
                    <ui:Button Icon="{ui:SymbolIcon ChevronUp24}" ToolTip="Previous page" Command="{Binding PreviousPageCommand}" Style="{StaticResource GroupedToolbarButtonStyle}" Margin="0,0,6,0"
                               Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <ui:Button Icon="{ui:SymbolIcon ChevronDown24}" ToolTip="Next page" Command="{Binding NextPageCommand}" Style="{StaticResource GroupedToolbarButtonStyle}" Margin="0,0,12,0"
                               Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <ui:Button Content="Zoom in" Icon="{ui:SymbolIcon ZoomIn24}" Command="{Binding ZoomInCommand}" Style="{StaticResource GroupedToolbarButtonWideStyle}" Margin="0,0,6,0" />
                    <ui:Button Content="Zoom out" Icon="{ui:SymbolIcon ZoomOut24}" Command="{Binding ZoomOutCommand}" Style="{StaticResource GroupedToolbarButtonWideStyle}" Margin="0,0,6,0" />
                    <ui:Button Content="Fit width" Icon="{ui:SymbolIcon ArrowFit24}" Command="{Binding FitToWidthCommand}" Style="{StaticResource GroupedToolbarButtonWideStyle}" Margin="0,0,6,0" />
                    <ui:Button Content="Fit page" Command="{Binding FitToPageCommand}" Style="{StaticResource GroupedToolbarButtonWideStyle}" Margin="0,0,6,0" />
                    <ui:Button Content="Rotate" Icon="{ui:SymbolIcon ArrowRotateClockwise24}" Command="{Binding RotateCommand}" Style="{StaticResource GroupedToolbarButtonWideStyle}" Margin="0,0,12,0" />
                    <ui:Button Content="Print" Icon="{ui:SymbolIcon Print24}" Command="{Binding PrintCommand}" Style="{StaticResource GroupedToolbarButtonWideStyle}" Margin="0,0,6,0" />
                    <ui:Button Content="Save as" Icon="{ui:SymbolIcon Save24}" Command="{Binding SaveAsCommand}" Style="{StaticResource GroupedToolbarButtonWideStyle}" Margin="0,0,6,0" />
                    <ui:Button Content="Open original" Icon="{ui:SymbolIcon Open24}" Command="{Binding OpenOriginalCommand}" Style="{StaticResource GroupedToolbarButtonWideStyle}" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Border Background="{StaticResource BrandAccentFillBrush}" CornerRadius="8" Padding="10,4" Margin="0,0,8,0"
                            Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding PagePositionText}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandAccentSoftBrush}" />
                    </Border>
                    <Border Background="{StaticResource BrandAccentFillBrush}" CornerRadius="8" Padding="10,4">
                        <TextBlock Text="{Binding PositionText}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandAccentSoftBrush}" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="16,0,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="112" Margin="0,0,12,0" CornerRadius="12"
                    Background="#0B1218"
                    BorderBrush="{StaticResource BrandBorderBrush}"
                    BorderThickness="1"
                    Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding PageThumbnails}" Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,0,8" Padding="4" Background="Transparent" BorderThickness="0"
                                        Command="{Binding DataContext.SelectPageCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                        CommandParameter="{Binding PageNumber}">
                                    <Border CornerRadius="6" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1" Padding="2">
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" MaxHeight="120" />
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" CornerRadius="14"
                    Background="#0B1218"
                    BorderBrush="{StaticResource BrandBorderBrush}"
                    BorderThickness="1"
                    ClipToBounds="True"
                    Effect="{StaticResource CardShadow}">
                <ScrollViewer x:Name="ViewerScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="Transparent">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="200" MinHeight="200">
                        <Image Source="{Binding ImageSource}"
                               Stretch="None"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               RenderTransformOrigin="0.5,0.5"
                               Visibility="{Binding HasRenderableContent, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}" />
                                    <RotateTransform Angle="{Binding Rotation}" />
                                    <TranslateTransform X="{Binding PanX}" Y="{Binding PanY}" />
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding HasRenderableContent, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <Border Style="{StaticResource IconBadgeLargeStyle}"
                                    Background="{StaticResource BrandAccentFillBrush}"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,16">
                                <ui:SymbolIcon Symbol="Document24" FontSize="26"
                                               Foreground="{StaticResource BrandAccentSoftBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Preview not available yet" FontSize="16" Foreground="White"
                                       HorizontalAlignment="Center" FontWeight="SemiBold" />
                            <TextBlock Text="Processing may still be running, or preview generation failed."
                                       Foreground="#9AADB8" Margin="0,8,0,16"
                                       TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center" />
                            <ui:Button Content="Open original" Style="{StaticResource PrimaryButtonStyle}"
                                       Command="{Binding OpenOriginalCommand}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource DialogFooterStyle}" Margin="0">
            <ui:Button Content="Close" HorizontalAlignment="Right" Style="{StaticResource DialogFooterButtonStyle}" Command="{Binding CloseCommand}" />
        </Border>
    </Grid>
</ui:FluentWindow>
