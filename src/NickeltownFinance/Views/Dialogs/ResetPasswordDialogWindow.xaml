<ui:FluentWindow x:Class="NickeltownFinance.Views.Dialogs.ResetPasswordDialogWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:ds="clr-namespace:NickeltownFinance.Controls"
                 Title="Reset Password"
                 Width="460"
                 SizeToContent="Height"
                 MinHeight="420"
                 MaxHeight="640"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Background="{StaticResource BrandBackgroundBrush}"
                 FontFamily="{StaticResource AppFontFamily}">
    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
        <KeyBinding Key="Enter" Command="{Binding ResetCommand}" />
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Reset password" Grid.Row="0" ShowMinimize="False" ShowMaximize="False" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,8,28,8">
            <StackPanel>
                <TextBlock Text="Reset password for"
                           Style="{StaticResource CaptionTextStyle}" />
                <TextBlock Text="{Binding TargetDisplay}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrandTextPrimaryBrush}"
                           Margin="0,2,0,6" />
                <TextBlock Text="Confirm your administrator password, then choose a new password for this account."
                           Style="{StaticResource PageSubtitleStyle}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,18" />

                <TextBlock Text="Your administrator password" Style="{StaticResource FieldLabelStyle}" />
                <ui:PasswordBox Password="{Binding AdminPassword, Mode=TwoWay}"
                                Margin="0,0,0,16" />

                <TextBlock Text="New password" Style="{StaticResource FieldLabelStyle}" />
                <ui:PasswordBox Password="{Binding NewPassword, Mode=TwoWay}" Margin="0,0,0,4" />
                <ProgressBar Minimum="0" Maximum="4" Value="{Binding PasswordStrength}" Height="6" Margin="0,0,0,2"
                             Foreground="{Binding PasswordStrength, Converter={StaticResource PasswordStrengthBrushConverter}}" />
                <TextBlock Text="{Binding PasswordStrengthLabel}" Opacity="0.7" FontSize="11" Margin="0,0,0,12" />

                <TextBlock Text="Confirm new password" Style="{StaticResource FieldLabelStyle}" />
                <ui:PasswordBox Password="{Binding ConfirmPassword, Mode=TwoWay}" Margin="0,0,0,10" />

                <TextBlock Text="Use 8+ characters with uppercase, lowercase, a number, and a special character."
                           Opacity="0.55" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />

                <ds:ErrorScreen Message="{Binding ErrorMessage}" IsCompact="True" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource DialogFooterStyle}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancel"
                           Style="{StaticResource GroupedSecondaryButtonWideStyle}"
                           Command="{Binding CancelCommand}"
                           Margin="{StaticResource ButtonGroupMarginInline}"
                           IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                <ui:Button Content="Reset password"
                           Style="{StaticResource GroupedPrimaryButtonWideStyle}"
                           Command="{Binding ResetCommand}"
                           IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
