<ui:FluentWindow x:Class="NickeltownFinance.Views.Dialogs.MobileReceiptUploadWindow"

                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"

                 xmlns:ds="clr-namespace:NickeltownFinance.Controls"

                 Title="Mobile Receipt Upload"

                 Width="460"

                 SizeToContent="Height"

                 MinHeight="480"

                 MaxHeight="720"

                 WindowStartupLocation="CenterOwner"

                 ResizeMode="NoResize"

                 ShowInTaskbar="False"

                 ExtendsContentIntoTitleBar="True"

                 WindowBackdropType="Mica"

                 Background="{DynamicResource BrandBackgroundBrush}"

                 FontFamily="{StaticResource AppFontFamily}">

    <ui:FluentWindow.InputBindings>

        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />

    </ui:FluentWindow.InputBindings>



    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto" />

            <RowDefinition Height="*" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>



        <ui:TitleBar Title="Mobile receipt upload" Grid.Row="0" ShowMinimize="False" ShowMaximize="False" />



        <ScrollViewer Grid.Row="1"

                      VerticalScrollBarVisibility="Auto"

                      HorizontalScrollBarVisibility="Disabled"

                      Padding="28,8,28,8">

            <StackPanel MaxWidth="404">

                <TextBlock Text="Scan with your phone"

                           Style="{StaticResource SectionTitleStyle}"

                           HorizontalAlignment="Center"

                           Margin="0,0,0,8" />

                <TextBlock Text="Open your phone camera and scan the QR code below. Your phone must be on the same Wi‑Fi as this PC."

                           Style="{StaticResource CaptionTextStyle}"

                           TextWrapping="Wrap"

                           TextAlignment="Center"

                           Margin="0,0,0,20" />



                <Border Style="{StaticResource AppCardStyle}"

                        Padding="24"

                        HorizontalAlignment="Center"

                        Margin="0,0,0,16">

                    <Image Source="{Binding QrCodeImage}"

                           Width="240"

                           Height="240"

                           Stretch="Uniform"

                           RenderOptions.BitmapScalingMode="NearestNeighbor" />

                </Border>



                <Border Background="{DynamicResource BrandSurfaceBrush}"

                        BorderBrush="{DynamicResource BrandBorderSubtleBrush}"

                        BorderThickness="1"

                        CornerRadius="10"

                        Padding="12,10"

                        HorizontalAlignment="Center"

                        Margin="0,0,0,12">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <ui:SymbolIcon Symbol="Clock24"

                                       FontSize="14"

                                       Foreground="{StaticResource BrandMutedTextBrush}"

                                       VerticalAlignment="Center"

                                       Margin="0,0,8,0" />

                        <TextBlock Style="{StaticResource MutedTextStyle}" VerticalAlignment="Center">

                            <Run Text="Session expires in" />

                            <Run Text="{Binding ExpiryCountdown, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextPrimaryBrush}" />

                        </TextBlock>

                    </StackPanel>

                </Border>



                <TextBlock Text="{Binding NetworkHint}"

                           Style="{StaticResource MutedTextStyle}"

                           HorizontalAlignment="Center"

                           TextAlignment="Center"

                           Margin="0,0,0,12" />



                <ui:Button Content="Copy link"

                           Style="{StaticResource GroupedSecondaryButtonStyle}"

                           HorizontalAlignment="Center"

                           Icon="{ui:SymbolIcon Copy24}"

                           Command="{Binding CopyLinkCommand}"

                           IsEnabled="{Binding IsSessionActive}"

                           Margin="0,0,0,16" />



                <TextBlock Text="Receipts appear in your inbox on this PC as soon as they are uploaded."

                           Style="{StaticResource CaptionTextStyle}"

                           TextWrapping="Wrap"

                           TextAlignment="Center"

                           Margin="0,0,0,8" />



                <ds:ErrorScreen Message="{Binding ErrorMessage}" IsCompact="True" />

            </StackPanel>

        </ScrollViewer>



        <Border Grid.Row="2" Style="{StaticResource DialogFooterStyle}">

            <Grid>

                <ui:Button Content="Refresh QR"

                           Style="{StaticResource DialogFooterButtonStyle}"

                           HorizontalAlignment="Left"

                           Command="{Binding RefreshSessionCommand}"

                           IsEnabled="{Binding IsSessionActive}" />



                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <ui:Button Content="Close session"

                               Style="{StaticResource GroupedDangerButtonStyle}"

                               Width="120"

                               Command="{Binding CloseSessionCommand}"

                               Margin="{StaticResource ButtonGroupMarginInline}" />

                    <ui:Button Content="Done"

                               Style="{StaticResource DialogFooterPrimaryButtonStyle}"

                               Command="{Binding CancelCommand}" />

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</ui:FluentWindow>

