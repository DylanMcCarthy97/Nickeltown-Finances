<ui:FluentWindow x:Class="NickeltownFinance.Views.Dialogs.TransactionEditorWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:ds="clr-namespace:NickeltownFinance.Controls"
                 Title="{Binding Title}"
                 Width="920" Height="820"
                 MinWidth="640" MinHeight="580"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="CanResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Background="{DynamicResource BrandBackgroundBrush}"
                 FontFamily="{StaticResource AppFontFamily}"
                 Icon="pack://application:,,,/Assets/AppIcon.png"
                 AllowDrop="True"
                 Drop="OnDrop"
                 DragOver="OnDragOver"
                 PreviewKeyDown="OnPreviewKeyDown">
    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="{Binding Title}" Grid.Row="0" ShowMinimize="False" ShowMaximize="False" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,8,28,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Style="{StaticResource IconBadgeLargeStyle}"
                            Background="{StaticResource BrandAccentFillBrush}"
                            Margin="0,0,14,0">
                        <ui:SymbolIcon Symbol="Money24" FontSize="22"
                                       Foreground="{StaticResource BrandPrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitleStyle}" FontSize="20" />
                        <TextBlock Text="Ctrl+S to save · Esc to cancel"
                                   Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                </StackPanel>

                <Border Style="{StaticResource AppCardStyle}" Margin="0,0,0,14" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Type" Style="{StaticResource FieldLabelStyle}" />
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button Content="Income" Height="44" FontSize="15" FontWeight="SemiBold"
                                       Command="{Binding SetIncomeCommand}">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource SuccessButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsIncome}" Value="False">
                                                <Setter Property="Opacity" Value="0.45" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                            <ui:Button Grid.Column="2" Content="Expense" Height="44" FontSize="15" FontWeight="SemiBold"
                                       Command="{Binding SetExpenseCommand}">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource DangerButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsIncome}" Value="True">
                                                <Setter Property="Opacity" Value="0.45" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                        </Grid>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="Date" Style="{StaticResource FieldLabelStyle}" />
                                <ds:AppDateField SelectedDate="{Binding Date}" MinHeight="40" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,0,14">
                                <TextBlock Text="Amount" Style="{StaticResource FieldLabelStyle}" />
                                <ui:NumberBox Value="{Binding Amount}" Minimum="0" Height="40"
                                              SpinButtonPlacementMode="Hidden" FontSize="16" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,0,14">
                                <TextBlock Text="Category" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                                          DisplayMemberPath="Name" Height="40" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,14">
                                <TextBlock Text="Payment method" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedPaymentMethod}"
                                          Height="40" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="0,0,0,14"
                                        Visibility="{Binding ShowCategoryTags, Converter={StaticResource BoolToVisibilityConverter}}">
                                <CheckBox Content="Also mark as other categories"
                                          IsChecked="{Binding MarkAdditionalCategories}"
                                          Margin="0,0,0,8" />
                                <TextBlock Text="Tags only — the full amount stays on the main category above. Use this when one transaction should also show under another category (e.g. bar + pitstop, or fixing a legacy import)."
                                           Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,0,0,8"
                                           Visibility="{Binding MarkAdditionalCategories, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                <StackPanel Visibility="{Binding MarkAdditionalCategories, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{Binding CategoryTags}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox ItemsSource="{Binding DataContext.Categories, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedItem="{Binding SelectedCategory}"
                                                              DisplayMemberPath="Name" Height="36" />
                                                    <ui:Button Grid.Column="2" Appearance="Secondary" Content="Remove"
                                                               Command="{Binding DataContext.RemoveCategoryTagLineCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                               CommandParameter="{Binding}" Padding="10,4" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ui:Button Appearance="Secondary" Content="Add category"
                                               Command="{Binding AddCategoryTagLineCommand}"
                                               Padding="12,6" HorizontalAlignment="Left" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Margin="0,0,0,14">
                                <TextBlock Text="Description" Style="{StaticResource FieldLabelStyle}" />
                                <ui:TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="What was this for?" FontSize="15" />
                                <CheckBox Content="Always use this category for this description"
                                          IsChecked="{Binding AlwaysUseCategoryForDescription}"
                                          Margin="0,8,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.ColumnSpan="3" Margin="0,0,0,14">
                                <TextBlock Text="Reference / invoice #" Style="{StaticResource FieldLabelStyle}" />
                                <ui:TextBox Text="{Binding Reference, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="Invoice or receipt number (optional)" />
                            </StackPanel>

                            <StackPanel Grid.Row="5" Grid.ColumnSpan="3">
                                <TextBlock Text="Notes (optional)" Style="{StaticResource FieldLabelStyle}" />
                                <ui:TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="Optional notes" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="280" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1.1*" MinWidth="320" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Border Style="{StaticResource IconBadgeStyle}" Background="{StaticResource BrandBalanceFillBrush}" Margin="0,0,12,0">
                                    <ui:SymbolIcon Symbol="Attach24" FontSize="18"
                                                   Foreground="{StaticResource BrandBalanceBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Receipts &amp; attachments" FontWeight="SemiBold" FontSize="15" />
                                    <TextBlock Text="Mobile, browse, scan, paste, or drag and drop."
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>

                            <ComboBox ItemsSource="{Binding AttachmentKinds}" SelectedItem="{Binding SelectedAttachmentKind}"
                                      Width="140" Margin="0,0,0,10" HorizontalAlignment="Left" />

                            <UniformGrid Columns="3" Margin="0,0,0,10">
                                <ui:Button Content="Mobile" Icon="{ui:SymbolIcon Phone24}" Command="{Binding MobileUploadCommand}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,6,6" />
                                <ui:Button Content="Browse" Icon="{ui:SymbolIcon FolderOpen24}" Command="{Binding BrowseAttachmentCommand}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,6,6" />
                                <ui:Button Content="Scan" Icon="{ui:SymbolIcon Scan24}" Command="{Binding ScanAttachmentCommand}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,6" />
                                <ui:Button Content="Paste" Icon="{ui:SymbolIcon ClipboardPaste24}" Command="{Binding PasteAttachmentCommand}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,6,0" />
                                <ui:Button Content="View" Icon="{ui:SymbolIcon Eye24}" Command="{Binding ViewAttachmentCommand}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,6,0" />
                                <ui:Button Content="Remove" Icon="{ui:SymbolIcon Delete24}" Command="{Binding RemoveAttachmentCommand}" Style="{StaticResource DangerButtonStyle}" HorizontalAlignment="Stretch" />
                            </UniformGrid>

                            <TextBlock Text="{Binding MobileUploadStatus}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,0,0,8"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding IsMobileUploadActive, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <ui:Button Content="Retry processing"
                                       Style="{StaticResource SecondaryButtonStyle}"
                                       Command="{Binding RetryReceiptProcessingCommand}"
                                       Visibility="{Binding CanRetryReceiptProcessing, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Margin="0,0,0,8" HorizontalAlignment="Left" />

                            <ui:Button Content="Discard upload"
                                       Style="{StaticResource DangerButtonStyle}"
                                       Command="{Binding DiscardMobileUploadCommand}"
                                       Visibility="{Binding HasPendingMobileUpload, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Margin="0,0,0,8" HorizontalAlignment="Left" />

                            <Border Background="{DynamicResource BrandInsetBrush}" CornerRadius="10" Padding="4" MinHeight="88">
                                <ListBox ItemsSource="{Binding Attachments}"
                                         SelectedItem="{Binding SelectedAttachment}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         MaxHeight="180"
                                         MouseDoubleClick="Attachments_OnMouseDoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="4,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Background="{StaticResource BrandAccentFillBrush}" CornerRadius="6"
                                                        Padding="8,4" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding Kind}" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource BrandAccentSoftBrush}" />
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding FileName}" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}" Margin="12,0,0,0"
                                                           Style="{StaticResource MutedTextStyle}" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="2" Background="{DynamicResource BrandInsetBrush}" CornerRadius="12" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" MinHeight="280" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Margin="0,0,0,10">
                                    <Border DockPanel.Dock="Right" CornerRadius="999" Padding="10,4" Margin="8,0,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BrandAccentFillBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ReceiptStatusBadge}" Value="Failed">
                                                        <Setter Property="Background" Value="#FEE2E2" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ReceiptStatusBadge}" Value="Ready">
                                                        <Setter Property="Background" Value="#DCFCE7" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ReceiptStatusBadge}" Value="Processing">
                                                        <Setter Property="Background" Value="#DBEAFE" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ReceiptStatusBadge}" Value="Matched">
                                                        <Setter Property="Background" Value="#E0E7FF" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding ReceiptStatusBadge}" FontWeight="SemiBold" FontSize="12" />
                                    </Border>
                                    <TextBlock Text="Receipt preview" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                                </DockPanel>

                                <Border Grid.Row="1" Background="{DynamicResource BrandBackgroundBrush}" CornerRadius="10" ClipToBounds="True">
                                    <Grid>
                                        <TextBlock Text="Add or upload a receipt to preview it here."
                                                   Style="{StaticResource MutedTextStyle}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   Margin="24"
                                                   Visibility="{Binding HasReceiptPreview, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                        <Viewbox Stretch="Uniform"
                                                 StretchDirection="DownOnly"
                                                 Visibility="{Binding HasReceiptPreview, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Image Source="{Binding PreviewImage}"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   RenderTransformOrigin="0.5,0.5">
                                                <Image.RenderTransform>
                                                    <TransformGroup>
                                                        <ScaleTransform ScaleX="{Binding PreviewZoom}" ScaleY="{Binding PreviewZoom}" />
                                                        <RotateTransform Angle="{Binding PreviewRotation}" />
                                                    </TransformGroup>
                                                </Image.RenderTransform>
                                            </Image>
                                        </Viewbox>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                    <TextBlock Text="{Binding ReceiptStatusDetail}"
                                               Style="{StaticResource CaptionTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8" />
                                    <WrapPanel>
                                        <ui:Button Content="Zoom +" Command="{Binding PreviewZoomInCommand}" Style="{StaticResource GroupedToolbarButtonStyle}" Margin="0,0,6,6" />
                                        <ui:Button Content="Zoom −" Command="{Binding PreviewZoomOutCommand}" Style="{StaticResource GroupedToolbarButtonStyle}" Margin="0,0,6,6" />
                                        <ui:Button Content="Fit width" Command="{Binding PreviewFitWidthCommand}" Style="{StaticResource GroupedToolbarButtonStyle}" Margin="0,0,6,6" />
                                        <ui:Button Content="Fit page" Command="{Binding PreviewFitPageCommand}" Style="{StaticResource GroupedToolbarButtonStyle}" Margin="0,0,6,6" />
                                        <ui:Button Content="Rotate" Command="{Binding PreviewRotateCommand}" Style="{StaticResource GroupedToolbarButtonStyle}" Margin="0,0,6,6" />
                                        <ui:Button Content="Previous" Command="{Binding PreviewPreviousCommand}" Style="{StaticResource GroupedToolbarButtonStyle}" Margin="0,0,6,6" />
                                        <ui:Button Content="Next" Command="{Binding PreviewNextCommand}" Style="{StaticResource GroupedToolbarButtonStyle}" Margin="0,0,6,6" />
                                        <ui:Button Content="Open" Command="{Binding OpenPreviewOriginalCommand}" Style="{StaticResource GroupedToolbarButtonStyle}" Margin="0,0,6,6" />
                                        <ui:Button Content="Download" Command="{Binding DownloadPreviewCommand}" Style="{StaticResource GroupedToolbarButtonStyle}" Margin="0,0,6,6" />
                                    </WrapPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <ds:ErrorScreen Message="{Binding ErrorMessage}" IsCompact="True" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource DialogFooterStyle}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancel"
                           Style="{StaticResource DialogFooterButtonStyle}"
                           Margin="{StaticResource ButtonGroupMarginInline}"
                           Command="{Binding CancelCommand}" />
                <ui:Button Content="Save"
                           Style="{StaticResource DialogFooterPrimaryButtonStyle}"
                           Icon="{ui:SymbolIcon Save24}"
                           Command="{Binding SaveCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
