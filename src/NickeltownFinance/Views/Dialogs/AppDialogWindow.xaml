<ui:FluentWindow x:Class="NickeltownFinance.Views.Dialogs.AppDialogWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{Binding TitleText}"
                 Width="480"
                 SizeToContent="Height"
                 MinHeight="200"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Background="Transparent"
                 FontFamily="{StaticResource AppFontFamily}">
    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
        <KeyBinding Key="Enter" Command="{Binding PrimaryCommand}" />
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="{Binding TitleText}"
                     Grid.Row="0"
                     ShowMinimize="False"
                     ShowMaximize="False" />

        <Grid Grid.Row="1" Margin="{StaticResource DialogContentPadding}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Width="52" Height="52"
                    CornerRadius="14"
                    Background="{Binding IconBackground}"
                    VerticalAlignment="Top"
                    Margin="0,2,18,0">
                <ui:SymbolIcon Symbol="{Binding IconSymbol}"
                               FontSize="24"
                               Foreground="{Binding IconForeground}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding TitleText}"
                           Style="{StaticResource SectionTitleStyle}"
                           FontSize="18"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding MessageText}"
                           Style="{StaticResource BodyTextStyle}"
                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                           LineHeight="22" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource DialogFooterStyle}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="{Binding SecondaryText}"
                           Command="{Binding CancelCommand}"
                           Style="{StaticResource DialogFooterButtonStyle}"
                           Margin="{StaticResource ButtonGroupMarginInline}"
                           Visibility="{Binding ShowSecondary, Converter={StaticResource BoolToVisibilityConverter}}" />
                <ui:Button Content="{Binding PrimaryText}"
                           Command="{Binding PrimaryCommand}"
                           Appearance="{Binding PrimaryAppearance}"
                           Style="{StaticResource DialogFooterPrimaryButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
